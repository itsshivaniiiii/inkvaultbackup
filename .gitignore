*.py
*.pyc

# ===========================================
# Dev/Debug Scripts & Temporary Code
# ===========================================
*.ps1
*.sh
*_NEW.cs
*_NEW.*
*_OLD.cs
*_BACKUP.*
Utilities/EmailDiagnostic.cs
EMAIL_DIAGNOSTIC_INSTRUCTIONS.txt

