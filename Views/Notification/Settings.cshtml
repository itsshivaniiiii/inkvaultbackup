@model InkVault.ViewModels.NotificationSettingsViewModel

@{
    ViewData["Title"] = "Notification Settings";
}

<style>
    .settings-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
        animation: fadeInUp 0.8s ease;
    }

    .settings-header {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 40px;
        padding-bottom: 20px;
        border-bottom: 2px solid rgba(102, 126, 234, 0.3);
    }

    .settings-header h1 {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        margin-bottom: 30px;
    }

    .back-link:hover {
        background: rgba(102, 126, 234, 0.3);
        color: #667eea;
        text-decoration: none;
    }

    .settings-section {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 25px;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 2px solid rgba(102, 126, 234, 0.3);
        color: var(--text-primary);
    }

    .section-title i {
        font-size: 1.4rem;
        color: #667eea;
    }

    .settings-group {
        margin-bottom: 20px;
    }

    .setting-item {
        display: flex;
        align-items: center;
        padding: 15px;
        background: rgba(255, 255, 255, 0.5);
        border-radius: 8px;
        margin-bottom: 12px;
        transition: all 0.3s ease;
    }

    .setting-item:hover {
        background: rgba(255, 255, 255, 0.7);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.15);
    }

    .setting-item input[type="checkbox"] {
        width: 24px;
        height: 24px;
        margin-right: 15px;
        cursor: pointer;
        accent-color: #667eea;
    }

    .setting-label {
        flex: 1;
    }

    .setting-label label {
        display: block;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 3px;
        cursor: pointer;
    }

    .setting-description {
        font-size: 0.85rem;
        color: var(--text-secondary);
        margin-left: 39px;
    }

    .button-group {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 30px;
    }

    .btn-save {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        color: white;
        text-decoration: none;
    }

    .btn-cancel {
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
        border: 1px solid rgba(102, 126, 234, 0.3);
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-cancel:hover {
        background: rgba(102, 126, 234, 0.3);
        color: #667eea;
        text-decoration: none;
    }

    .alert-success {
        background: rgba(76, 175, 80, 0.15);
        border: 1px solid rgba(76, 175, 80, 0.3);
        color: #4caf50;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .alert-success i {
        font-size: 1.2rem;
    }

    [data-theme="light"] .settings-section {
        background: #ffffff;
        border-color: rgba(102, 126, 234, 0.15);
    }

    [data-theme="light"] .setting-item {
        background: rgba(102, 126, 234, 0.05);
    }

    [data-theme="light"] .setting-item:hover {
        background: rgba(102, 126, 234, 0.1);
    }

    @@media (max-width: 768px) {
        .settings-container {
            padding: 15px;
        }

        .settings-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .button-group {
            flex-direction: column;
        }

        .btn-save, .btn-cancel {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="settings-container">
    <a href="@Url.Action("Index", "Profile")" class="back-link">
        <i class="bi bi-arrow-left"></i> Back to Profile
    </a>

    <div class="settings-header">
        <i class="bi bi-bell" style="font-size: 2.5rem; color: #667eea;"></i>
        <h1>Notification Settings</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    <form method="post" action="@Url.Action("UpdateSettings", "Notification")">
        @Html.AntiForgeryToken()

        <!-- Friends Notifications Section -->
        <div class="settings-section">
            <div class="section-title">
                <i class="bi bi-people"></i>
                Friends Notifications
            </div>

            <div class="settings-group">
                <div class="setting-item">
                    <input type="checkbox" id="EmailOnFriendRequestReceived" name="EmailOnFriendRequestReceived" value="true"
                           @(Model.EmailOnFriendRequestReceived ? "checked" : "") />
                    <div class="setting-label">
                        <label for="EmailOnFriendRequestReceived">
                            When a follow/friend request is received
                        </label>
                    </div>
                </div>

                <div class="setting-item">
                    <input type="checkbox" id="EmailOnFriendRequestAccepted" name="EmailOnFriendRequestAccepted" value="true"
                           @(Model.EmailOnFriendRequestAccepted ? "checked" : "") />
                    <div class="setting-label">
                        <label for="EmailOnFriendRequestAccepted">
                            When your follow/friend request is accepted
                        </label>
                    </div>
                </div>

                <div class="setting-item">
                    <input type="checkbox" id="EmailOnFriendRequestDenied" name="EmailOnFriendRequestDenied" value="true"
                           @(Model.EmailOnFriendRequestDenied ? "checked" : "") />
                    <div class="setting-label">
                        <label for="EmailOnFriendRequestDenied">
                            When your follow/friend request is denied
                        </label>
                    </div>
                </div>

                <div class="setting-item">
                    <input type="checkbox" id="EmailOnFriendJournalPost" name="EmailOnFriendJournalPost" value="true"
                           @(Model.EmailOnFriendJournalPost ? "checked" : "") />
                    <div class="setting-label">
                        <label for="EmailOnFriendJournalPost">
                            When a friend posts a new journal
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Security & Login Notifications Section -->
        <div class="settings-section">
            <div class="section-title">
                <i class="bi bi-shield-lock"></i>
                Security & Login
            </div>

            <div class="settings-group">
                <div class="setting-item">
                    <input type="checkbox" id="RequireOTPOnEveryLogin" name="RequireOTPOnEveryLogin" value="true"
                           @(Model.RequireOTPOnEveryLogin ? "checked" : "") />
                    <div class="setting-label">
                        <label for="RequireOTPOnEveryLogin">
                            Require OTP verification on every login
                        </label>
                        <div class="setting-description">
                            Add an extra layer of security by requiring OTP on each login attempt
                        </div>
                    </div>
                </div>

                <div class="setting-item">
                    <input type="checkbox" id="EmailOnSuccessfulLogin" name="EmailOnSuccessfulLogin" value="true"
                           @(Model.EmailOnSuccessfulLogin ? "checked" : "") />
                    <div class="setting-label">
                        <label for="EmailOnSuccessfulLogin">
                            Email notification on successful login
                        </label>
                        <div class="setting-description">
                            Receive an email with browser and login details each time you log in
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="button-group">
            <a href="@Url.Action("Index", "Profile")" class="btn-cancel">
                <i class="bi bi-x-circle"></i> Cancel
            </a>
            <button type="submit" class="btn-save">
                <i class="bi bi-check-circle"></i> Save Changes
            </button>
        </div>
    </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('form');
    
    form.addEventListener('submit', function(e) {
        // Get all checkbox inputs
        const checkboxes = form.querySelectorAll('input[type="checkbox"]');
        
        // For each checkbox that is NOT checked, add a hidden input with false value
        checkboxes.forEach(checkbox => {
            if (!checkbox.checked) {
                // Create a hidden input for unchecked boxes
                const hiddenInput = document.createElement('input');
                hiddenInput.type = 'hidden';
                hiddenInput.name = checkbox.name;
                hiddenInput.value = 'false';
                
                // Only add if not already present
                if (!form.querySelector(`input[type="hidden"][name="${checkbox.name}"]`)) {
                    form.appendChild(hiddenInput);
                }
            }
        });
    });
});
</script>
