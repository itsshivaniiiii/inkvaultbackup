@model InkVault.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
    ViewData["ForceDark"] = true;
}

<div class="min-vh-100 d-flex align-items-center" style="background: linear-gradient(135deg, #0f1419 0%, #1a1f2e 100%);">
<div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <!-- Logo Section -->
                <div class="text-center mb-4">
                    <img src="~/Images/logo.png" alt="InkVault Logo" style="height: 160px; object-fit: contain;">
                </div>

                <!-- Register Card -->
                <div class="card p-4 shadow" style="max-width: 500px; margin: auto;">
                    <h3 class="mb-3 text-center">Create New Account</h3>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="text-danger mb-2"></div>
                    }

                    <form asp-action="Register" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="mb-2">
                            <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>

                        <div class="mb-2">
                            <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>

                        <div class="mb-2">
                            <input asp-for="Username" class="form-control" placeholder="Username" />
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>

                        <div class="mb-2">
                            <input asp-for="Email" class="form-control" placeholder="Email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-2">
                            <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-2">
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-2">
                            <select asp-for="Gender" class="form-select">
                                <option value="">Select gender</option>
                                <option>Male</option>
                                <option>Female</option>
                                <option>Don't prefer to say</option>
                            </select>
                            <span asp-validation-for="Gender" class="text-danger"></span>
                        </div>

                        <div class="mb-2">
                            <label asp-for="DateOfBirth" class="form-label">Date of Birth (optional)</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                        </div>

                        <div class="mb-2">
                            <input asp-for="PhoneNumber" class="form-control" placeholder="Phone number" type="tel" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProfilePicture" class="form-label">Profile picture (optional)</label>
                            <input asp-for="ProfilePicture" type="file" class="form-control" />
                            <span asp-validation-for="ProfilePicture" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Register</button>
                    </form>

                    <div class="text-center mt-3">
                        <p>Already have an account? <a asp-controller="Account" asp-action="Welcome">Login here</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Force dark inputs regardless of theme setting */
    .form-control, .form-select {
        background-color: #1a1f2e !important;
        border: 1px solid rgba(102, 126, 234, 0.3) !important;
        color: #e0e0e0 !important;
    }

    .form-control::placeholder {
        color: #7a7a8c !important;
    }

    .form-control:focus {
        background-color: #1a1f2e !important;
        border-color: #667eea !important;
        color: #e0e0e0 !important;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25) !important;
    }

    .card {
        background-color: #1a1f2e !important;
        border: 1px solid rgba(102, 126, 234, 0.2) !important;
        color: #e0e0e0 !important;
    }

    .card h3, .card label, .card p, .card a {
        color: #e0e0e0 !important;
    }

    .form-check-label {
        color: #b0b0b0 !important;
    }

    input[type="file"]::file-selector-button {
        background-color: #2a2f42 !important;
        border: 1px solid rgba(102, 126, 234, 0.3) !important;
        color: #e0e0e0 !important;
        padding: 0.375rem 0.75rem;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

    input[type="file"]::file-selector-button:hover {
        background-color: rgba(102, 126, 234, 0.25) !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
