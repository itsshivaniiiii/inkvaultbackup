@model InkVault.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<style>
    .profile-container {
        max-width: 900px;
        margin: 0 auto;
        animation: fadeInUp 0.8s ease;
    }

    .profile-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 40px;
        padding: 30px;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
    }

    .profile-avatar-wrapper {
        position: relative;
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 700;
        color: white;
        flex-shrink: 0;
        border: 3px solid rgba(102, 126, 234, 0.3);
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
    }

    .profile-avatar:hover {
        transform: scale(1.05);
        border-color: #667eea;
        box-shadow: 0 0 20px rgba(102, 126, 234, 0.4);
    }

    .profile-avatar img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
    }

    .profile-avatar-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .profile-avatar:hover .profile-avatar-overlay {
        opacity: 1;
    }

    .profile-avatar-overlay i {
        font-size: 1.5rem;
        color: white;
    }

    #profilePictureInput {
        display: none;
    }

    .remove-picture-btn {
        position: absolute;
        bottom: -10px;
        right: -10px;
        width: 40px;
        height: 40px;
        background: #ff6b6b;
        border: 2px solid white;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.2rem;
        transition: all 0.3s ease;
        opacity: 0;
    }

    .profile-avatar-wrapper:hover .remove-picture-btn {
        opacity: 1;
    }

    .remove-picture-btn:hover {
        background: #ff5252;
        transform: scale(1.1);
    }

    .profile-info h2 {
        font-size: 1.8rem;
        margin: 0 0 10px 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .profile-info p {
        margin: 5px 0;
        color: var(--text-secondary);
    }

    .section-card {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 25px;
    }

    .section-title {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid rgba(102, 126, 234, 0.2);
        color: var(--text-primary);
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--text-primary);
    }

    .form-control, .form-select {
        background: linear-gradient(135deg, rgba(26, 31, 46, 0.9) 0%, rgba(26, 31, 46, 0.8) 100%);
        border: 1px solid rgba(102, 126, 234, 0.3);
        color: var(--text-primary);
        border-radius: 8px;
        padding: 12px 15px;
        width: 100%;
        transition: all 0.3s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .theme-toggle {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .theme-option {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 20px;
        background: rgba(102, 126, 234, 0.2);
        border: 2px solid rgba(102, 126, 234, 0.3);
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .theme-option.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-color: #667eea;
        color: white;
    }

    .theme-option input {
        display: none;
    }

    .btn-primary, .btn-danger {
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        color: white;
        text-decoration: none;
    }

    .btn-danger {
        background: rgba(255, 107, 107, 0.2);
        color: #ff6b6b;
        border: 1px solid rgba(255, 107, 107, 0.3);
    }

    .btn-danger:hover {
        background: rgba(255, 107, 107, 0.3);
        color: #ff6b6b;
        text-decoration: none;
    }

    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 25px;
    }

    .stat-item {
        padding: 15px;
        background: rgba(102, 126, 234, 0.1);
        border-radius: 8px;
        text-align: left;
    }

    .stat-label {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-bottom: 5px;
    }

    .stat-value {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-primary);
        word-break: break-all;
    }

    @@media (max-width: 768px) {
        .profile-header {
            flex-direction: column;
            text-align: center;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .form-actions {
            flex-direction: column;
        }

        .theme-toggle {
            flex-direction: column;
            width: 100%;
        }

        .theme-option {
            width: 100%;
            justify-content: center;
        }
    }

    /* Light Theme Styles for Profile */
    [data-theme="light"] .profile-container {
        color: var(--text-primary);
    }

    [data-theme="light"] .form-control,
    [data-theme="light"] .form-select {
        background: #ffffff !important;
        border-color: rgba(102, 126, 234, 0.3) !important;
        color: var(--text-primary) !important;
    }

    [data-theme="light"] .form-control:focus,
    [data-theme="light"] .form-select:focus {
        border-color: #667eea !important;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25) !important;
    }

    [data-theme="light"] .form-group label {
        color: var(--text-primary) !important;
    }

    [data-theme="light"] .stat-item {
        background: rgba(102, 126, 234, 0.05) !important;
    }

    [data-theme="light"] .section-card {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
        border-color: rgba(102, 126, 234, 0.15) !important;
    }

    [data-theme="light"] .section-title {
        color: var(--text-primary) !important;
        border-bottom-color: rgba(102, 126, 234, 0.15) !important;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        margin-bottom: 30px;
    }

    .back-btn:hover {
        background: rgba(102, 126, 234, 0.3);
        color: #667eea;
        text-decoration: none;
    }

</style>

<div class="profile-container">
    <a href="@Url.Action("Index", "Home")" class="back-btn">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Profile Header -->
    <div class="profile-header">
        <div class="profile-avatar-wrapper">
            <label for="profilePictureInput" class="profile-avatar">
                @if (!string.IsNullOrEmpty(Model?.ProfilePictureUrl))
                {
                    <img src="@Model.ProfilePictureUrl" alt="Profile Picture" />
                }
                else
                {
                    <span>@Model?.FirstName?[0]@Model?.LastName?[0]</span>
                }
                <div class="profile-avatar-overlay">
                    <i class="bi bi-camera-fill"></i>
                </div>
            </label>
            
            @if (!string.IsNullOrEmpty(Model?.ProfilePictureUrl))
            {
                <form method="post" action="@Url.Action("RemoveProfilePicture", "Profile")" style="display: inline;" onsubmit="return confirm('Remove profile picture?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="remove-picture-btn" title="Remove picture">
                        <i class="bi bi-x"></i>
                    </button>
                </form>
            }

            <input type="file" id="profilePictureInput" name="profilePicture" accept="image/*" />
        </div>

        <div class="profile-info">
            <h2>@Model?.FirstName @Model?.LastName</h2>
            <p><i class="bi bi-at"></i> @Model?.Username</p>
            <p><i class="bi bi-envelope"></i> @Model?.Email</p>
            @if (!string.IsNullOrEmpty(Model?.PhoneNumber))
            {
                <p><i class="bi bi-telephone"></i> @Model?.PhoneNumber</p>
            }
        </div>
    </div>

    <!-- Personal Information -->
    <form method="post" action="@Url.Action("UpdateProfile", "Profile")" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="section-card">
            <h3 class="section-title">
                <i class="bi bi-person-circle"></i> Personal Information
            </h3>

            <div class="form-row">
                <div class="form-group">
                    <label for="FirstName">First Name</label>
                    <input type="text" class="form-control" id="FirstName" name="FirstName" value="@Model?.FirstName" required />
                </div>
                <div class="form-group">
                    <label for="LastName">Last Name</label>
                    <input type="text" class="form-control" id="LastName" name="LastName" value="@Model?.LastName" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="Email">Email Address</label>
                    <input type="email" class="form-control" id="Email" name="Email" value="@Model?.Email" disabled />
                    <small style="color: var(--text-secondary);">Email cannot be changed</small>
                </div>
                <div class="form-group">
                    <label for="PhoneNumber">Phone Number</label>
                    <input type="tel" class="form-control" id="PhoneNumber" name="PhoneNumber" placeholder="+1 (555) 000-0000" value="@Model?.PhoneNumber" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="Gender">Gender</label>
                    <select class="form-select" id="Gender" name="Gender">
                        <option value="Not Specified" selected="@(string.IsNullOrEmpty(Model?.Gender) || Model?.Gender == "Not Specified")">Prefer not to say</option>
                        <option value="Male" selected="@(Model?.Gender == "Male")">Male</option>
                        <option value="Female" selected="@(Model?.Gender == "Female")">Female</option>
                        <option value="Other" selected="@(Model?.Gender == "Other")">Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="DateOfBirth">Date of Birth</label>
                    <input type="date" class="form-control" id="DateOfBirth" name="DateOfBirth" value="@(Model?.DateOfBirth?.ToString("yyyy-MM-dd"))" />
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">
                    <i class="bi bi-check-circle"></i> Save Changes
                </button>
            </div>
        </div>
    </form>

    <!-- Danger Zone -->
    <div class="section-card" style="border-color: rgba(255, 107, 107, 0.3); background: linear-gradient(135deg, rgba(255, 107, 107, 0.05) 0%, rgba(255, 107, 107, 0.02) 100%);">
        <h3 class="section-title" style="color: #ff6b6b; border-bottom-color: rgba(255, 107, 107, 0.3);">
            <i class="bi bi-exclamation-triangle"></i> Danger Zone
        </h3>

        <p style="color: var(--text-secondary); margin-bottom: 20px;">These actions cannot be undone</p>

        <form method="post" action="@Url.Action("DeleteAccount", "Profile")" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete your account? This action cannot be undone.');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-danger">
                <i class="bi bi-trash"></i> Delete Account
            </button>
        </form>
    </div>
</div>

<script>
    // Handle profile picture file selection
    const profileInput = document.getElementById('profilePictureInput');
    const profileForm = profileInput.closest('form') || document.createElement('form');

    profileInput.addEventListener('change', function (e) {
        if (this.files && this.files.length > 0) {
            // Create a form and submit with the file
            const formData = new FormData();
            formData.append('profilePicture', this.files[0]);
            formData.append('FirstName', document.getElementById('FirstName').value);
            formData.append('LastName', document.getElementById('LastName').value);
            formData.append('PhoneNumber', document.getElementById('PhoneNumber').value);
            formData.append('Gender', document.getElementById('Gender').value);

            // Add CSRF token
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            if (token) {
                formData.append('__RequestVerificationToken', token);
            }

            fetch('@Url.Action("UpdateProfile", "Profile")', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (response.ok) {
                    location.reload();
                } else {
                    alert('Error uploading profile picture');
                }
            })
            .catch(err => console.error('Error:', err));
        }
    });

    // Load saved theme from localStorage
    const savedTheme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', savedTheme);
</script>

