<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InkVault</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InkVault.styles.css" asp-append-version="true" />
    
    <!-- CRITICAL: Apply theme IMMEDIATELY before any content renders -->
    <script>
        // Run immediately, before DOMContentLoaded
        (function() {
            // Get saved theme from localStorage
            var savedTheme = localStorage.getItem('theme-preference') || localStorage.getItem('theme') || 'dark';
            
            // Validate theme
            if (savedTheme !== 'dark' && savedTheme !== 'light') {
                savedTheme = 'dark';
            }
            
            // Apply to html element IMMEDIATELY
            document.documentElement.setAttribute('data-theme', savedTheme);
            
            // Apply to body when it exists
            document.addEventListener('DOMContentLoaded', function() {
                document.body.setAttribute('data-theme', savedTheme);
            });
            
            // DEBUG
            console.log('Head script - Initial theme:', savedTheme);
        })();
    </script>

    <style>
        :root {
            --primary-color: #667eea;
            --secondary-color: #764ba2;
            --accent-color: #f093fb;
            --dark-bg: #0f1419;
            --card-bg: #1a1f2e;
            --text-primary: #e0e0e0;
            --text-secondary: #b0b0b0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'Apple Color Emoji', 'Segoe UI Emoji', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #0f1419;
            color: #e0e0e0;
            font-family: 'Segoe UI', 'Apple Color Emoji', 'Segoe UI Emoji', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* Navbar Styles */
        .navbar {
            background-color: rgba(26, 31, 46, 0.95) !important;
            border-bottom: 1px solid rgba(102, 126, 234, 0.2) !important;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
            overflow: visible !important;
            z-index: 1050;
        }

        .navbar-brand {
            font-size: 1.5rem;
            font-weight: 700;
            color: #667eea !important;
            cursor: default;
            pointer-events: none;
            transition: color 0.3s ease;
        }

        .nav-link {
            color: #e0e0e0 !important;
            transition: all 0.3s ease;
            position: relative;
        }

        .nav-link:hover {
            color: #667eea !important;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, #667eea, #764ba2);
            transition: width 0.3s ease;
        }

        .nav-link:hover::after {
            width: 100%;
        }

        /* Navbar collapse overflow */
        .navbar-collapse {
            overflow: visible !important;
        }

        .navbar-nav {
            overflow: visible !important;
        }

        /* Dropdown Styles */
        .dropdown-menu {
            background-color: #1a1f2e !important;
            border: 1px solid rgba(102, 126, 234, 0.3) !important;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            transition: all 0.3s ease;
            z-index: 9999 !important;
            position: absolute !important;
            top: 100% !important;
            right: 0 !important;
            min-width: 200px !important;
        }

        .dropdown-item {
            color: #e0e0e0 !important;
            transition: all 0.2s ease;
            background-color: transparent;
            font-family: 'Segoe UI', 'Apple Color Emoji', 'Segoe UI Emoji', sans-serif;
            padding: 0.75rem 1rem !important;
            display: block !important;
            width: 100% !important;
        }

        .dropdown-item:hover {
            background-color: rgba(102, 126, 234, 0.2) !important;
            color: #ffffff !important;
        }

        .dropdown-item:active {
            background-color: rgba(102, 126, 234, 0.3) !important;
            color: #ffffff !important;
        }

        .dropdown-item.text-danger {
            color: #ff6b6b !important;
        }

        .dropdown-item.text-danger:hover {
            background-color: rgba(211, 47, 47, 0.2) !important;
            color: #ff6b6b !important;
        }

        /* ========================================
           LIGHT THEME - Override Dark Theme
           ======================================== */

        [data-theme="light"] body {
            background-color: #f8f9fa;
            color: #1a1a1a;
        }

        /* Light theme CSS variables */
        [data-theme="light"] {
            --primary-color: #667eea;
            --secondary-color: #764ba2;
            --accent-color: #f093fb;
            --dark-bg: #f8f9fa;
            --card-bg: #ffffff;
            --text-primary: #1a1a1a;
            --text-secondary: #555555;
        }

        [data-theme="light"] .navbar {
            background-color: #ffffff !important;
            border-bottom: 1px solid rgba(102, 126, 234, 0.15) !important;
        }

        [data-theme="light"] .navbar-brand {
            color: #667eea !important;
        }

        [data-theme="light"] .nav-link {
            color: #1a1a1a !important;
        }

        [data-theme="light"] .nav-link:hover {
            color: #667eea !important;
        }

        [data-theme="light"] .card {
            background-color: #ffffff !important;
            border-color: rgba(102, 126, 234, 0.2) !important;
            color: #1a1a1a !important;
        }

        [data-theme="light"] .form-control,
        [data-theme="light"] .form-select {
            background-color: #ffffff !important;
            border-color: rgba(102, 126, 234, 0.3) !important;
            color: #1a1a1a !important;
        }

        [data-theme="light"] .form-control::placeholder {
            color: #999999 !important;
        }

        [data-theme="light"] .form-control:focus {
            border-color: #667eea !important;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25) !important;
        }

        [data-theme="light"] .alert {
            background-color: rgba(102, 126, 234, 0.1);
            border-color: rgba(102, 126, 234, 0.2);
            color: #2c3e50;
        }



        [data-theme="light"] .dropdown-menu {
            background-color: #ffffff !important;
            border: 1px solid rgba(102, 126, 234, 0.2) !important;
            border-radius: 8px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1) !important;
            z-index: 9999 !important;
            position: absolute !important;
            top: 100% !important;
            right: 0 !important;
            min-width: 200px !important;
        }

        [data-theme="light"] .dropdown-item {
            color: #1a1a1a !important;
            background-color: transparent !important;
            transition: all 0.2s ease;
            padding: 0.75rem 1rem !important;
            display: block !important;
            width: 100% !important;
        }

        [data-theme="light"] .dropdown-item:hover {
            background-color: rgba(102, 126, 234, 0.08) !important;
            color: #667eea !important;
        }

        [data-theme="light"] .dropdown-item:active {
            background-color: rgba(102, 126, 234, 0.15) !important;
            color: #667eea !important;
        }

        [data-theme="light"] .dropdown-divider {
            border-top: 1px solid rgba(102, 126, 234, 0.1) !important;
        }

        [data-theme="light"] .dropdown-item.text-danger {
            color: #d32f2f !important;
        }

        [data-theme="light"] .dropdown-item.text-danger:hover {
            background-color: rgba(211, 47, 47, 0.08) !important;
            color: #d32f2f !important;
        }

        [data-theme="light"] main {
            background-color: #f8f9fa;
            color: #1a1a1a;
        }

        [data-theme="light"] .footer {
            background-color: #ffffff !important;
            border-top: 1px solid rgba(102, 126, 234, 0.1) !important;
            color: #666666;
        }

        [data-theme="light"] .footer a {
            color: #667eea;
        }

        [data-theme="light"] .navbar-text {
            color: #667eea !important;
        }

        [data-theme="light"] .text-muted {
            color: #777777 !important;
        }

        [data-theme="light"] .text-danger {
            color: #d32f2f !important;
        }

        [data-theme="light"] .text-success {
            color: #388e3c !important;
        }

        [data-theme="light"] .text-warning {
            color: #f57c00 !important;
        }

        [data-theme="light"] .text-info {
            color: #1976d2 !important;
        }

        /* Light theme gradient text fixes */
        [data-theme="light"] .explore-header h1 {
            background: none !important;
            -webkit-background-clip: unset !important;
            -webkit-text-fill-color: unset !important;
            background-clip: unset !important;
            color: #1a1a1a !important;
        }

        [data-theme="light"] .back-btn {
            background: rgba(102, 126, 234, 0.1) !important;
            color: #667eea !important;
            border-color: rgba(102, 126, 234, 0.2) !important;
        }

        [data-theme="light"] .back-btn:hover {
            background: rgba(102, 126, 234, 0.15) !important;
            color: #667eea !important;
        }

        [data-theme="light"] .search-input input {
            background: #ffffff !important;
            color: #1a1a1a !important;
            border-color: rgba(102, 126, 234, 0.2) !important;
        }

        [data-theme="light"] .search-input input::placeholder {
            color: #999999 !important;
        }

        [data-theme="light"] .search-input input:focus {
            border-color: #667eea !important;
        }

        /* Remove gradient text in light theme */
        [data-theme="light"] .journal-section-title,
        [data-theme="light"] .section-title,
        [data-theme="light"] .page-title {
            background: none !important;
            -webkit-background-clip: unset !important;
            -webkit-text-fill-color: unset !important;
            background-clip: unset !important;
            color: #1a1a1a !important;
        }

        [data-theme="light"] .journal-card h3,
        [data-theme="light"] .journal-item h3,
        [data-theme="light"] .explore-card h3,
        [data-theme="light"] .card h3 {
            color: #1a1a1a !important;
            background: none !important;
        }

        [data-theme="light"] .journal-card,
        [data-theme="light"] .journal-item,
        [data-theme="light"] .explore-card {
            background-color: #ffffff !important;
            color: #1a1a1a !important;
            border-color: rgba(102, 126, 234, 0.1) !important;
        }

        [data-theme="light"] .journal-card p,
        [data-theme="light"] .journal-item p,
        [data-theme="light"] .explore-card p,
        [data-theme="light"] .card p {
            color: #555555 !important;
        }

        [data-theme="light"] h1,
        [data-theme="light"] h2,
        [data-theme="light"] h3,
        [data-theme="light"] h4,
        [data-theme="light"] h5,
        [data-theme="light"] h6 {
            color: #1a1a1a;
        }

        [data-theme="light"] p {
            color: #1a1a1a;
        }

        [data-theme="light"] table {
            color: #1a1a1a;
        }

        [data-theme="light"] thead {
            background-color: #e8eaf6;
            color: #1a1a1a;
        }

        [data-theme="light"] th {
            color: #1a1a1a !important;
        }

        [data-theme="light"] tbody tr:hover {
            background-color: rgba(102, 126, 234, 0.08);
        }

        [data-theme="light"] td {
            color: #1a1a1a;
        }

        /* Dark theme tables for visibility */
        table {
            color: #e0e0e0;
        }

        thead {
            background-color: rgba(102, 126, 234, 0.1);
            color: #e0e0e0;
        }

        th {
            color: #e0e0e0 !important;
        }

        tbody tr:hover {
            background-color: rgba(102, 126, 234, 0.1);
        }

        td {
            color: #e0e0e0;
        }

        /* Emoji support for both themes */
        .navbar-brand,
        .nav-link,
        .dropdown-item,
        button,
        a {
            font-family: 'Segoe UI', 'Apple Color Emoji', 'Segoe UI Emoji', sans-serif;
        }

        [data-theme="light"] .btn-primary {
            background-color: #667eea !important;
            border-color: #667eea !important;
            color: white !important;
        }

        [data-theme="light"] .btn-primary:hover {
            background-color: #5568d3 !important;
            border-color: #5568d3 !important;
        }

        [data-theme="light"] .btn-secondary {
            background-color: #764ba2 !important;
            border-color: #764ba2 !important;
        }

        [data-theme="light"] .btn-danger {
            background-color: #f44336 !important;
            border-color: #f44336 !important;
        }

        [data-theme="light"] .footer a {
            color: #667eea;
        }

        [data-theme="light"] .navbar-text {
            color: #667eea !important;
        }

        [data-theme="light"] .nav-link {
            color: #2c3e50 !important;
        }

        [data-theme="light"] .nav-link:hover {
            color: #667eea !important;
        }

        [data-theme="light"] .btn-primary {
            background-color: #667eea !important;
            border-color: #667eea !important;
            color: white !important;
        }

        [data-theme="light"] .btn-primary:hover {
            background-color: #5568d3 !important;
            border-color: #5568d3 !important;
        }

        [data-theme="light"] .text-muted {
            color: #888888 !important;
        }

        [data-theme="light"] h1,
        [data-theme="light"] h2,
        [data-theme="light"] h3,
        [data-theme="light"] h4,
        [data-theme="light"] h5,
        [data-theme="light"] h6 {
            color: #1a1f2e;
        }

        [data-theme="light"] table {
            color: #2c3e50;
        }

        [data-theme="light"] thead {
            background-color: #f0f1f5;
            color: #2c3e50;
        }

        /* Main Container */
        .container {
            position: relative;
        }

        /* Animations */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes glow {
            0%, 100% {
                box-shadow: 0 0 20px rgba(102, 126, 234, 0.3);
            }
            50% {
                box-shadow: 0 0 40px rgba(240, 147, 251, 0.5);
            }
        }

        @@keyframes pulse {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.7;
            }
        }

        /* Footer */
        .footer {
            background: linear-gradient(90deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
            border-top: 1px solid rgba(102, 126, 234, 0.2);
            color: var(--text-secondary);
            margin-top: 50px;
        }

        /* Utility Classes */
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }

        main {
            animation: fadeInUp 0.6s ease;
        }

        /* Toast Animations */
        @@keyframes slideInRight {
            from {
                transform: translateX(400px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @@keyframes slideOutRight {
            from {
                transform: translateX(0);
                opacity: 1;
            }
            to {
                transform: translateX(400px);
                opacity: 0;
            }
        }
    </style>
</head>
<body>
<!-- Toast Container -->
<div id="toastContainer" style="position: fixed; top: 20px; right: 20px; z-index: 9999; pointer-events: none;"></div>

<header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom mb-3">
            <div class="container-fluid">
                <span class="navbar-brand">
                    <div>InkVault</div>
                    <div style="font-size: 0.65rem; opacity: 0.8; font-weight: 400; margin-top: -5px;">Secure your thoughts</div>
                </span>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Home
                            </a>
                        </li>
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Journal" asp-action="MyJournals">
                                    <i class="bi bi-pencil-square"></i> My Journals
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Explore" asp-action="Index">
                                    <i class="bi bi-compass"></i> Explore
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Friends" asp-action="Index">
                                    <i class="bi bi-people"></i> Friends
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <span class="navbar-text me-3" style="font-size: 1.1rem; font-weight: bold; color: #667eea;">
                                    <i class="bi bi-person-circle"></i> @@<span>@User.Identity.Name</span>
                                </span>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="settingsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-gear"></i> Settings
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="settingsDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                            <i class="bi bi-person-circle"></i> My Profile
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" href="javascript:void(0);" id="themeToggle" style="cursor: pointer;">
                                            <i class="bi bi-sun"></i> <span id="themeText">Light Theme</span>
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline w-100">
                                            <button type="submit" class="dropdown-item" style="color: #f44336;">
                                                <i class="bi bi-box-arrow-right"></i> Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Welcome">
                                    <i class="bi bi-box-arrow-in-right"></i> Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus"></i> Register
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - InkVault - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    @if (User?.Identity?.IsAuthenticated ?? false)
    {
        <script>
            // Toastr options
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "showDuration": "300",
                "hideDuration": "1000",
                "timeOut": "5000",
                "extendedTimeOut": "1000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            };
        </script>
    }

    @if (User?.Identity?.IsAuthenticated ?? false)
    {
        <script>
            // ================================================
            // THEME MANAGEMENT - PERSISTENT & RELIABLE
            // ================================================
            
            const THEME_STORAGE_KEY = 'theme-preference';
            const VALID_THEMES = ['dark', 'light'];
            
            // Immediately read and apply stored theme
            (function() {
                console.log('=== THEME SYSTEM INITIALIZED ===');
                
                // Get theme from localStorage
                var storedTheme = localStorage.getItem(THEME_STORAGE_KEY) || localStorage.getItem('theme');
                console.log('Stored theme:', storedTheme);
                
                // Validate
                if (!VALID_THEMES.includes(storedTheme)) {
                    storedTheme = 'dark';
                }
                
                console.log('Applying theme:', storedTheme);
                
                // Apply immediately
                document.documentElement.setAttribute('data-theme', storedTheme);
                document.body.setAttribute('data-theme', storedTheme);
                
                // Update UI to match current theme
                function updateUI(theme) {
                    const themeToggle = document.getElementById('themeToggle');
                    const themeText = document.getElementById('themeText');
                    const themeIcon = themeToggle?.querySelector('i');
                    
                    if (theme === 'light') {
                        if (themeIcon) themeIcon.className = 'bi bi-moon-stars';
                        if (themeText) themeText.textContent = 'Dark Theme';
                    } else {
                        if (themeIcon) themeIcon.className = 'bi bi-sun';
                        if (themeText) themeText.textContent = 'Light Theme';
                    }
                }
                
                // Update UI once DOM is ready
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', () => updateUI(storedTheme));
                } else {
                    updateUI(storedTheme);
                }
                
                // Setup theme toggle
                function setupToggle() {
                    const themeToggle = document.getElementById('themeToggle');
                    if (!themeToggle) return;
                    
                    themeToggle.addEventListener('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        
                        console.log('Theme toggle clicked');
                        
                        // Get current theme
                        const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
                        console.log('Current theme:', currentTheme);
                        
                        // Calculate new theme
                        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                        console.log('Switching to:', newTheme);
                        
                        // Apply immediately to DOM
                        document.documentElement.setAttribute('data-theme', newTheme);
                        document.body.setAttribute('data-theme', newTheme);
                        
                        // Save to localStorage IMMEDIATELY
                        localStorage.setItem(THEME_STORAGE_KEY, newTheme);
                        localStorage.setItem('theme', newTheme);
                        console.log('Saved to localStorage:', newTheme);
                        
                        // Update UI
                        updateUI(newTheme);
                        
                        // Try to sync with server (non-blocking)
                        fetch('@Url.Action("ChangeTheme", "Profile")', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': getToken()
                            },
                            credentials: 'same-origin',
                            body: JSON.stringify({ theme: newTheme })
                        }).catch(() => {
                            console.log('Server sync skipped - using localStorage only');
                        });
                    });
                }
                
                // Setup once DOM is ready
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', setupToggle);
                } else {
                    setupToggle();
                }
            })();
            
            function getToken() {
                const meta = document.querySelector('meta[name="csrf-token"]');
                return meta ? meta.getAttribute('content') : '';
            }
            
            // Ensure theme persists during navigation
            window.addEventListener('beforeunload', function() {
                const theme = document.documentElement.getAttribute('data-theme') || 'dark';
                console.log('Saving theme before unload:', theme);
                localStorage.setItem(THEME_STORAGE_KEY, theme);
                localStorage.setItem('theme', theme);
            });

            // Toast notification function
            function showToast(message, type = 'success') {
                const toastContainer = document.getElementById('toastContainer');
                const toastId = 'toast-' + Date.now();
                
                let bgColor, iconClass;
                switch(type) {
                    case 'success':
                        bgColor = '#10b981';
                        iconClass = 'bi-check-circle-fill';
                        break;
                    case 'error':
                        bgColor = '#ef4444';
                        iconClass = 'bi-exclamation-circle-fill';
                        break;
                    case 'warning':
                        bgColor = '#f59e0b';
                        iconClass = 'bi-exclamation-triangle-fill';
                        break;
                    default:
                        bgColor = '#3b82f6';
                        iconClass = 'bi-info-circle-fill';
                }
                
                const toastHTML = `
                    <div id="${toastId}" style="
                        background: ${bgColor};
                        color: white;
                        padding: 16px 24px;
                        border-radius: 8px;
                        margin-bottom: 10px;
                        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
                        display: flex;
                        align-items: center;
                        gap: 12px;
                        animation: slideInRight 0.3s ease;
                        min-width: 300px;
                        pointer-events: auto;
                    ">
                        <i class="bi ${iconClass}" style="font-size: 1.2rem; flex-shrink: 0;"></i>
                        <span>${message}</span>
                    </div>
                `;
                
                if (toastContainer) {
                    toastContainer.insertAdjacentHTML('beforeend', toastHTML);
                }
                
                // Auto remove after 4 seconds
                setTimeout(() => {
                    const toast = document.getElementById(toastId);
                    if (toast) {
                        toast.style.animation = 'slideOutRight 0.3s ease';
                        setTimeout(() => toast.remove(), 300);
                    }
                }, 4000);
            }

            // Display TempData messages as toasts
            @if (TempData["Success"] != null) {
                <text>
                    showToast('@Html.Raw(TempData["Success"])', 'success');
                </text>
            }
            @if (TempData["Error"] != null) {
                <text>
                    showToast('@Html.Raw(TempData["Error"])', 'error');
                </text>
            }
            @if (TempData["Warning"] != null) {
                <text>
                    showToast('@Html.Raw(TempData["Warning"])', 'warning');
                </text>
            }
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
