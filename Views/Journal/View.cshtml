@model InkVault.Models.Journal

@{
    ViewData["Title"] = Model?.Title ?? "View Journal";
}

<style>
    .journal-viewer {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 40px;
        max-width: 900px;
        margin: 0 auto;
        animation: slideInLeft 0.6s ease;
    }

    .journal-header {
        margin-bottom: 30px;
        padding-bottom: 30px;
        border-bottom: 2px solid rgba(102, 126, 234, 0.2);
    }

    .journal-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0 0 20px 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .journal-badges {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .badge-published {
        background: rgba(102, 200, 100, 0.2);
        color: #66c864;
    }

    .badge-private {
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
    }

    .badge-public {
        background: rgba(240, 147, 251, 0.2);
        color: #f093fb;
    }

    .journal-content {
        background: linear-gradient(135deg, rgba(26, 31, 46, 0.5) 0%, rgba(26, 31, 46, 0.3) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 30px;
        color: var(--text-primary);
        line-height: 1.8;
        font-size: 1.05rem;
        margin-bottom: 30px;
        min-height: 300px;
    }

    /* Light theme styles */
    [data-theme="light"] .journal-viewer {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
    }

    [data-theme="light"] .journal-content {
        background: #ffffff;
        border: 1px solid rgba(102, 126, 234, 0.15);
        color: #2c3e50;
    }

    [data-theme="light"] .journal-header {
        border-bottom-color: rgba(102, 126, 234, 0.15);
    }

    [data-theme="light"] .journal-actions {
        border-top-color: rgba(102, 126, 234, 0.15);
    }

    .journal-actions {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 30px;
        border-top: 1px solid rgba(102, 126, 234, 0.2);
    }

    .btn-action {
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-edit {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .btn-edit:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        color: white;
        text-decoration: none;
    }

    .btn-back {
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
        border: 1px solid rgba(102, 126, 234, 0.3);
    }

    .btn-back:hover {
        background: rgba(102, 126, 234, 0.3);
        color: #667eea;
        text-decoration: none;
    }

    @@media (max-width: 768px) {
        .journal-viewer {
            padding: 20px;
        }

        .journal-title {
            font-size: 1.8rem;
        }

        .journal-actions {
            flex-direction: column;
        }

        .btn-action {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="journal-viewer">
    <div class="journal-header">
        <h1 class="journal-title">@Model?.Title</h1>

        <div class="journal-badges">
            <span class="badge badge-published">
                <i class="bi bi-cloud-check"></i>
                Published
            </span>
            <span class="badge @(Model?.PrivacyLevel == InkVault.Models.PrivacyLevel.Private ? "badge-private" : "badge-public")">
                <i class="bi @(Model?.PrivacyLevel == InkVault.Models.PrivacyLevel.Private ? "bi-lock" : "bi-globe")"></i>
                @(Model?.PrivacyLevel == InkVault.Models.PrivacyLevel.Private ? "Private" : "Public")
            </span>
        </div>
    </div>

    <!-- Journal Content -->
    <div class="journal-content">
        @Html.Raw(Model?.Content)
    </div>

    <!-- Actions -->
    <div class="journal-actions">
        @{
            var userId = User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            var fromBrowse = ViewBag.FromBrowse ?? false;
            var fromFeed = ViewBag.FromFeed ?? false;
            var topicName = ViewBag.TopicName ?? "";
        }
        
        @if (fromFeed)
        {
            <!-- Show only Friends Feed button when coming from feed -->
            <a href="@Url.Action("Index", "Feed")" class="btn-action btn-back">
                <i class="bi bi-arrow-left"></i> Back to Friends Feed
            </a>
        }
        else if (fromBrowse && !string.IsNullOrEmpty(topicName))
        {
            <!-- Show only Browse by Topic button when coming from browse/topic -->
            <a href="@Url.Action("ViewByTopic", "Topic", new { topicName = topicName })" class="btn-action btn-back">
                <i class="bi bi-arrow-left"></i> Back to Browse by Topic
            </a>
        }
        else if (Model?.UserId == userId)
        {
            <!-- Show My Journals and Edit for own journals when not from browse -->
            <a href="@Url.Action("MyJournals", "Journal")" class="btn-action btn-back">
                <i class="bi bi-arrow-left"></i> Back to My Journals
            </a>
            
            <a href="@Url.Action("Edit", "Journal", new { id = Model.JournalId })" class="btn-action btn-edit">
                <i class="bi bi-pencil"></i> Edit Journal
            </a>
        }
        else
        {
            <!-- For other users viewing, show generic back button -->
            <a href="@Url.Action("Index", "Explore")" class="btn-action btn-back">
                <i class="bi bi-arrow-left"></i> Back to Explore
            </a>
        }
    </div>
</div>
