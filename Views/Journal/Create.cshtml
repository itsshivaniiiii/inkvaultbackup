            <p style="color: var(--text-secondary); text-align: center; margin: 40px 0;">Click "Enhance" to improve your content with AI...</p>
        </div>

        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button type="button" onclick="closeEnhanceModal()" style="padding: 10px 20px; background: rgba(102, 126, 234, 0.2); color: #667eea; border: 1px solid rgba(102, 126, 234, 0.3); border-radius: 6px; cursor: pointer; font-weight: 600;">
                Cancel
            </button>
            <button type="button" id="discardEnhanceBtn" onclick="discardEnhancement()" style="padding: 10px 20px; background: rgba(255, 107, 107, 0.2); color: #ff6b6b; border: 1px solid rgba(255, 107, 107, 0.3); border-radius: 6px; cursor: pointer; font-weight: 600; display: none;">
