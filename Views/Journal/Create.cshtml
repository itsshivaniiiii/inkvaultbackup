            </button>
            <button type="button" id="enhanceNowBtn" onclick="enhanceContent()" style="padding: 10px 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 600;">
                Enhance
            </button>
        </div>

        <div id="enhanceStatus" style="margin-top: 15px; padding: 12px; background: rgba(102, 126, 234, 0.1); border-radius: 6px; color: var(--text-secondary); display: none; text-align: center;">
            <small></small>
        </div>
    </div>
</div>

