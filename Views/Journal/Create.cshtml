</style>

<script>
// AI Enhancement Modal Management
let originalContent = '';
let enhancedContent = '';

function openEnhanceModal() {
    const content = document.getElementById('Content').innerText.trim();
    
    if (!content || content.length < 10) {
        alert('Please write at least 10 characters before using AI enhancement.');
        return;
    }

    originalContent = document.getElementById('Content').innerHTML;
    document.getElementById('enhanceModal').style.display = 'flex';
    document.getElementById('enhanceNowBtn').style.display = 'block';
    document.getElementById('enhanceNowBtn').disabled = false;
    document.getElementById('acceptEnhanceBtn').style.display = 'none';
    document.getElementById('discardEnhanceBtn').style.display = 'none';
    document.getElementById('enhanceContent').innerHTML = '<p style="color: var(--text-secondary); text-align: center; margin: 40px 0;">Click "Enhance" to improve your content with AI...</p>';
    document.getElementById('enhanceStatus').style.display = 'none';
    enhancedContent = '';
}

function closeEnhanceModal() {
    document.getElementById('enhanceModal').style.display = 'none';
    originalContent = '';
    enhancedContent = '';
}

function showStatus(message, isError = false) {
    const status = document.getElementById('enhanceStatus');
    const isDarkTheme = document.documentElement.getAttribute('data-theme') !== 'light';
    
    let textColor;
    if (isError) {
        textColor = '#ff6b6b';
    } else {
        textColor = isDarkTheme ? '#667eea' : '#2c3e50';
    }
    
    status.innerHTML = `<small style="color: ${textColor}">${message}</small>`;
    status.style.display = 'block';
}

async function enhanceContent() {
const content = document.getElementById('Content').innerText.trim();
    
if (!content) {
    showStatus('No content to enhance', true);
    return;
}

if (content.length < 10) {
    showStatus('Content must be at least 10 characters', true);
    return;
}

document.getElementById('enhanceNowBtn').disabled = true;
showStatus('Enhancing your content... (this may take 10-30 seconds)');

    try {
        console.log('Sending content for enhancement:', content.substring(0, 100));

        // Get anti-forgery token from the page
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const response = await fetch('/Journal/EnhanceContent', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
                'RequestVerificationToken': token
            },
            body: JSON.stringify({ content: content })
        });

        const responseText = await response.text();
        console.log('Response status:', response.status);
        console.log('Response text:', responseText);

        // Parse the response
        let result;
        try {
            result = JSON.parse(responseText);
        } catch (parseError) {
            console.error('Parse error:', parseError);
            console.error('Response was:', responseText);
            throw new Error('Server error: Invalid response format');
        }

        // Check if request was successful
        if (!response.ok) {
            const errorMessage = result.error || `Error ${response.status}`;
            throw new Error(errorMessage);
        }

        // Check if we got enhanced content
        if (!result.enhanced) {
            throw new Error(result.error || 'No enhanced content returned');
        }

        enhancedContent = result.enhanced;
        console.log('Enhancement successful');

        // Display enhanced content
        document.getElementById('enhanceContent').innerHTML = `<p>${enhancedContent.replace(/\n/g, '</p><p>')}</p>`;
        
        // Show accept/discard buttons
        document.getElementById('enhanceNowBtn').style.display = 'none';
        document.getElementById('acceptEnhanceBtn').style.display = 'block';
        document.getElementById('discardEnhanceBtn').style.display = 'block';
        
        showStatus('Enhancement complete! Review and accept or discard.');
    } catch (error) {
        console.error('Enhancement error:', error);
        showStatus(`Error: ${error.message}`, true);
        document.getElementById('enhanceNowBtn').disabled = false;
        document.getElementById('enhanceNowBtn').style.display = 'block';
    }
}

// Custom success toast notification
function showSuccessToast(message) {
    const toast = document.createElement('div');
    toast.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
        color: white;
        padding: 16px 24px;
        border-radius: 8px;
        box-shadow: 0 4px 12px rgba(81, 207, 102, 0.4);
        font-weight: 600;
        z-index: 10000;
        animation: slideInRight 0.3s ease;
    `;
    toast.textContent = message;
    document.body.appendChild(toast);
    
    setTimeout(() => {
        toast.style.animation = 'slideOutRight 0.3s ease';
        setTimeout(() => toast.remove(), 300);
    }, 3000);
}

// Add CSS for toast if not already present
if (!document.getElementById('toast-styles')) {
    const style = document.createElement('style');
    style.id = 'toast-styles';
    style.textContent = '.success-toast { position: fixed; top: 20px; right: 20px; transition: all 0.3s ease; }';
    document.head.appendChild(style);
}

function acceptEnhancement() {
    if (!enhancedContent) return;

    document.getElementById('Content').innerHTML = enhancedContent;
    document.getElementById('ContentInput').value = enhancedContent;
    
    // Update counts
    updateCounts();
    
    closeEnhanceModal();
    showSuccessToast('Content enhanced successfully!');
}

function discardEnhancement() {
    // Reset to original
    document.getElementById('enhanceContent').innerHTML = '<p style="color: var(--text-secondary); text-align: center; margin: 40px 0;">Click "Enhance" to improve your content with AI...</p>';
    document.getElementById('enhanceNowBtn').style.display = 'block';
    document.getElementById('enhanceNowBtn').disabled = false;
    document.getElementById('acceptEnhanceBtn').style.display = 'none';
    document.getElementById('discardEnhanceBtn').style.display = 'none';
    document.getElementById('enhanceStatus').style.display = 'none';
    enhancedContent = '';
    
    // Close the modal
    closeEnhanceModal();
}

// Close modal when clicking outside
document.addEventListener('click', function(e) {
    const modal = document.getElementById('enhanceModal');
    if (e.target === modal) {
        closeEnhanceModal();
    }
});
</script>

<!-- Custom Link Modal -->
<div id="linkModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.5); z-index: 9999; align-items: center; justify-content: center;">
    <div style="background: var(--card-bg); border-radius: 12px; padding: 30px; max-width: 500px; width: 90%; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3); border: 1px solid rgba(102, 126, 234, 0.2);">
        <h3 style="margin-top: 0; color: var(--text-primary); font-weight: 700;">Insert Link</h3>
        
        <div style="margin-bottom: 20px;">
            <label for="linkUrl" style="display: block; font-weight: 600; margin-bottom: 8px; color: var(--text-primary);">URL</label>
            <input type="text" id="linkUrl" placeholder="https://example.com" style="width: 100%; padding: 12px; border: 1px solid rgba(102, 126, 234, 0.3); border-radius: 6px; background: var(--input-bg); color: var(--text-primary); box-sizing: border-box;" />
            <small id="linkUrlError" style="color: #ff6b6b; display: none; margin-top: 5px; display: block;"></small>
        </div>

        <div style="margin-bottom: 25px;">
            <label for="linkText" style="display: block; font-weight: 600; margin-bottom: 8px; color: var(--text-primary);">Link Text (Optional)</label>
            <input type="text" id="linkText" placeholder="Display text for the link" style="width: 100%; padding: 12px; border: 1px solid rgba(102, 126, 234, 0.3); border-radius: 6px; background: var(--input-bg); color: var(--text-primary); box-sizing: border-box;" />
        </div>

        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button type="button" onclick="closeLinkModal()" style="padding: 10px 20px; background: rgba(102, 126, 234, 0.2); color: #667eea; border: 1px solid rgba(102, 126, 234, 0.3); border-radius: 6px; cursor: pointer; font-weight: 600;">
                Cancel
            </button>
            <button type="button" onclick="insertLink()" style="padding: 10px 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 600;">
                Insert Link
            </button>
            <button type="button" id="removeLink" onclick="removeLink()" style="padding: 10px 20px; background: rgba(255, 107, 107, 0.2); color: #ff6b6b; border: 1px solid rgba(255, 107, 107, 0.3); border-radius: 6px; cursor: pointer; font-weight: 600; display: none;">
                Remove Link
            </button>
        </div>
    </div>
</div>

<style>
    /* Link Modal Styles */
    #linkModal[style*="display: flex"] {
        display: flex !important;
    }

    [data-theme="light"] #linkModal > div {
        background: #ffffff !important;
    }

    [data-theme="light"] #linkModal input {
        background: #ffffff !important;
        color: #2c3e50 !important;
    }
</style>

<script>
// Custom Link Modal Management
let currentLinkElement = null;
let savedSelection = null;

function openLinkModal() {
    const selection = window.getSelection();
    const linkModal = document.getElementById('linkModal');
    const linkUrl = document.getElementById('linkUrl');
    const linkText = document.getElementById('linkText');
    const linkUrlError = document.getElementById('linkUrlError');
    const removeLink = document.getElementById('removeLink');
    const editor = document.getElementById('Content');

    // Ensure editor is focused first
    editor.focus();

    // Clear previous errors
    linkUrlError.style.display = 'none';

    // Save current selection/cursor position
    if (selection.rangeCount > 0) {
        savedSelection = selection.getRangeAt(0).cloneRange();
    } else {
        // Create a range at the end of the editor if no selection
        savedSelection = document.createRange();
        savedSelection.selectNodeContents(editor);
        savedSelection.collapse(false); // Move to end
    }

    // Check if cursor is within an existing link
    let selectedLink = null;
    if (selection.rangeCount > 0) {
        const range = selection.getRangeAt(0);
        const container = range.commonAncestorContainer;
        const element = container.nodeType === 3 ? container.parentElement : container;

        // Look for existing link in the selection or cursor position
        selectedLink = element.closest('a');

        // If no direct link found, check if selection spans a link
        if (!selectedLink && selection.toString()) {
            const selectedContent = range.cloneContents();
            const links = selectedContent.querySelectorAll('a');
            if (links.length === 1) {
                // Find the corresponding link in the actual DOM
                const selectedText = selection.toString();
                const editorLinks = editor.querySelectorAll('a');
                selectedLink = Array.from(editorLinks).find(link => link.textContent === selectedText);
            }
        }
    }

    // Set up modal based on whether we're editing existing link or creating new
    currentLinkElement = selectedLink;

    if (selectedLink) {
        // Editing existing link
        linkUrl.value = selectedLink.href || '';
        linkText.value = selectedLink.textContent || '';
        removeLink.style.display = 'block';
    } else {
        // Creating new link
        linkUrl.value = '';
        linkText.value = selection.toString() || '';
        removeLink.style.display = 'none';
    }

    linkModal.style.display = 'flex';
    linkUrl.focus();
    linkUrl.select(); // Select all text for easier editing
}

function closeLinkModal() {
    document.getElementById('linkModal').style.display = 'none';
    document.getElementById('linkUrl').value = '';
    document.getElementById('linkText').value = '';
    document.getElementById('linkUrlError').style.display = 'none';
    currentLinkElement = null;
    savedSelection = null;

    // Return focus to editor
    document.getElementById('Content').focus();
}

function validateUrl(url) {
    if (!url || url.trim().length === 0) {
        return null;
    }

    try {
        let urlToValidate = url.trim();

        // Handle common URL patterns
        if (urlToValidate.startsWith('www.')) {
            urlToValidate = 'https://' + urlToValidate;
        } else if (!urlToValidate.match(/^https?:\/\//i)) {
            // Check if it looks like a domain (contains a dot)
            if (urlToValidate.includes('.')) {
                urlToValidate = 'https://' + urlToValidate;
            } else {
                return null; // Not a valid URL pattern
            }
        }

        // Validate using URL constructor
        const urlObj = new URL(urlToValidate);

        // Additional validation - must have valid protocol and host
        if (!['http:', 'https:'].includes(urlObj.protocol)) {
            return null;
        }

        if (!urlObj.hostname || urlObj.hostname.length === 0) {
            return null;
        }

        return urlToValidate;
    } catch (e) {
        return null;
    }
}

function insertLink() {
    const linkUrl = document.getElementById('linkUrl').value.trim();
    const linkText = document.getElementById('linkText').value.trim();
    const linkUrlError = document.getElementById('linkUrlError');
    const editor = document.getElementById('Content');

    // Clear previous errors
    linkUrlError.style.display = 'none';

    if (!linkUrl) {
        linkUrlError.textContent = 'URL is required';
        linkUrlError.style.display = 'block';
        return;
    }

    const validUrl = validateUrl(linkUrl);
    if (!validUrl) {
        linkUrlError.textContent = 'Invalid URL format';
        linkUrlError.style.display = 'block';
        return;
    }

    // Determine display text
    const displayText = linkText || validUrl;

    if (currentLinkElement) {
        // Edit existing link
        currentLinkElement.href = validUrl;
        currentLinkElement.target = '_blank';
        currentLinkElement.rel = 'noopener noreferrer';
        currentLinkElement.textContent = displayText;
    } else {
        // Create new link element
        const link = document.createElement('a');
        link.href = validUrl;
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
        link.style.color = '#667eea';
        link.style.textDecoration = 'underline';
        link.textContent = displayText;

        // Focus editor and restore selection
        editor.focus();

        const selection = window.getSelection();
        selection.removeAllRanges();

        if (savedSelection) {
            // Use saved selection
            selection.addRange(savedSelection);

            const selectedText = savedSelection.toString();
            if (selectedText.length > 0) {
                // Replace selected text with link
                savedSelection.deleteContents();
                savedSelection.insertNode(link);
            } else {
                // Insert at cursor position
                savedSelection.insertNode(link);

                // Add space after link if needed
                const nextSibling = link.nextSibling;
                if (!nextSibling || (nextSibling.nodeType === 3 && !nextSibling.textContent.startsWith(' '))) {
                    const spaceNode = document.createTextNode(' ');
                    link.parentNode.insertBefore(spaceNode, link.nextSibling);
                }
            }

            // Position cursor after the link
            const range = document.createRange();
            const nextNode = link.nextSibling;
            if (nextNode && nextNode.nodeType === 3) {
                range.setStart(nextNode, 1); // After the space
                range.setEnd(nextNode, 1);
            } else {
                range.setStartAfter(link);
                range.setEndAfter(link);
            }

            selection.removeAllRanges();
            selection.addRange(range);
        } else {
            // Fallback: append to end of editor
            const spaceNode = document.createTextNode(' ');
            editor.appendChild(spaceNode);
            editor.appendChild(link);
            editor.appendChild(document.createTextNode(' '));

            // Position cursor after link
            const range = document.createRange();
            range.setStartAfter(link);
            range.setEndAfter(link);
            selection.removeAllRanges();
            selection.addRange(range);
        }
    }

    // Force editor focus and sync content
    editor.focus();
    document.getElementById('ContentInput').value = editor.innerHTML;

    // Update character counts
    updateCounts();

    console.log('Link inserted successfully:', displayText, '?', validUrl);
    closeLinkModal();
}

function removeLink() {
    if (currentLinkElement) {
        const editor = document.getElementById('Content');
        const parent = currentLinkElement.parentNode;
        const textContent = currentLinkElement.textContent;

        // Create text node with the link's text content
        const textNode = document.createTextNode(textContent);

        // Replace the link with plain text
        parent.insertBefore(textNode, currentLinkElement);
        parent.removeChild(currentLinkElement);

        // Position cursor after the text
        const selection = window.getSelection();
        const range = document.createRange();
        range.setStartAfter(textNode);
        range.setEndAfter(textNode);
        selection.removeAllRanges();
        selection.addRange(range);

        // Focus editor and sync content
        editor.focus();
        document.getElementById('ContentInput').value = editor.innerHTML;
        updateCounts();
    }
    closeLinkModal();
}

// Close modal when clicking outside
document.getElementById('linkModal').addEventListener('click', function(e) {
    if (e.target === this) {
        closeLinkModal();
    }
});

// Keyboard support for link modal
document.getElementById('linkUrl').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
        e.preventDefault();
        console.log('Enter pressed in URL field, calling insertLink()');
        insertLink();
    } else if (e.key === 'Escape') {
        e.preventDefault();
        closeLinkModal();
    }
});

document.getElementById('linkText').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
        e.preventDefault();
        console.log('Enter pressed in text field, calling insertLink()');
        insertLink();
    } else if (e.key === 'Escape') {
        e.preventDefault();
        closeLinkModal();
    }
});

// Ensure Insert Link button is properly wired
document.addEventListener('DOMContentLoaded', function() {
    const insertLinkBtn = document.querySelector('#linkModal button[onclick="insertLink()"]');
    if (insertLinkBtn) {
        // Remove onclick attribute and add proper event listener
        insertLinkBtn.removeAttribute('onclick');
        insertLinkBtn.addEventListener('click', function(e) {
            e.preventDefault();
            console.log('Insert Link button clicked');
            insertLink();
        });
    }

    // Also ensure toolbar button works
    const toolbarLinkBtn = document.querySelector('[data-command="createLink"]');
    if (toolbarLinkBtn) {
        toolbarLinkBtn.addEventListener('click', function(e) {
            e.preventDefault();
            console.log('Toolbar link button clicked');
            openLinkModal();
        });
    }
});

// Replace default link button with custom modal (backup)
document.querySelector('[data-command="createLink"]')?.addEventListener('click', function(e) {
    e.preventDefault();
    console.log('Backup toolbar link handler triggered');
    openLinkModal();
});
</script>

