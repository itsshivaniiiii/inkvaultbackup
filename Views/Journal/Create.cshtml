            </button>
            <button type="button" id="acceptEnhanceBtn" onclick="acceptEnhancement()" style="padding: 10px 20px; background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%); color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; display: none;">
