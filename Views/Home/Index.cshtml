    }

    .friend-result-card:hover {
        border-color: #667eea;
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.15);
    }

    [data-theme="light"] .friend-result-card {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
        border-color: rgba(102, 126, 234, 0.15);
    }

    .friend-result-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        margin-right: 15px;
        flex-shrink: 0;
    }

    .friend-result-avatar img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
    }

    .friend-result-info {
        flex: 1;
    }

    .friend-result-name {
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 3px;
    }

    .friend-result-id {
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    .friend-result-actions {
        display: flex;
        gap: 8px;
    }

    .friend-action-btn {
        padding: 8px 16px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s ease;
    }

    .friend-action-btn.add-friend {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .friend-action-btn.add-friend:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
    }

    .friend-action-btn.friends {
        background: rgba(76, 175, 80, 0.2);
        color: #4caf50;
        border: 1px solid rgba(76, 175, 80, 0.3);
    }


    .friend-action-btn.pending {
        background: rgba(255, 193, 7, 0.2);
        color: #ffc107;
        border: 1px solid rgba(255, 193, 7, 0.3);
    }

    .friend-action-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(400px);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@keyframes slideOutRight {
        from {
            transform: translateX(0);
            opacity: 1;
        }
        to {
            transform: translateX(400px);
            opacity: 0;
        }
    }
</style>

<!-- Toast Notification Container -->
<div id="toastContainer" style="position: fixed; top: 20px; right: 20px; z-index: 9999;"></div>

<script>
// Store URLs at page load
var searchUsersUrl = '/Friends/SearchUsers';
var sendRequestUrl = '/Friends/SendRequest';



// Toast notification function
function showToast(message, type = 'success') {
    const toastContainer = document.getElementById('toastContainer');
    const toastId = 'toast-' + Date.now();
    
    const bgColor = type === 'success' ? '#10b981' : type === 'error' ? '#ef4444' : '#3b82f6';
    const icon = type === 'success' ? '✓' : type === 'error' ? '✕' : 'ℹ';
    
    const toastHTML = `
        <div id="${toastId}" style="
            background: ${bgColor};
            color: white;
            padding: 16px 24px;
            border-radius: 8px;
            margin-bottom: 10px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            display: flex;
            align-items: center;
            gap: 12px;
            animation: slideInRight 0.3s ease;
            min-width: 300px;
        ">
            <span style="font-weight: bold; font-size: 1.2rem;">${icon}</span>
            <span>${message}</span>
        </div>
    `;
    
    toastContainer.insertAdjacentHTML('beforeend', toastHTML);
    
    // Auto remove after 4 seconds
    setTimeout(() => {
        const toast = document.getElementById(toastId);
        if (toast) {
            toast.style.animation = 'slideOutRight 0.3s ease';
            setTimeout(() => toast.remove(), 300);
        }
    }, 4000);
}

function searchFriends() {
    const searchQuery = document.getElementById('friendSearchInput').value.trim();
        
    if (!searchQuery) {
        document.getElementById('searchResults').innerHTML = `
            <div style="text-align: center; padding: 40px 20px; color: var(--text-secondary);">
                <i class="bi bi-search" style="font-size: 3rem; opacity: 0.5; display: block; margin-bottom: 15px;"></i>
                <p>Start typing to search for friends</p>
            </div>
        `;
        return;
    }

    // Show loading state
    document.getElementById('searchResults').innerHTML = `
        <div style="text-align: center; padding: 40px 20px;">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p style="color: var(--text-secondary); margin-top: 15px;">Searching...</p>
        </div>
    `;

    // Fetch search results
    const url = searchUsersUrl + '?query=' + encodeURIComponent(searchQuery);
    fetch(url)
        .then(response => response.json())
        .then(data => {

            if (data.length === 0) {
                document.getElementById('searchResults').innerHTML = `
                    <div style="text-align: center; padding: 40px 20px; color: var(--text-secondary);">
                        <i class="bi bi-person-x" style="font-size: 3rem; opacity: 0.5; display: block; margin-bottom: 15px;"></i>
                        <p>No users found matching "${searchQuery}"</p>
                    </div>
                `;
                return;
            }

            let resultsHtml = '';
            data.forEach(user => {
                const avatar = user.profilePicturePath 
                    ? `<img src="${user.profilePicturePath}" alt="${user.firstName}">`
                    : `${user.firstName.charAt(0)}${user.lastName.charAt(0)}`;
                    
                let buttonHtml = '';
                if (user.friendStatus === 'friends') {
                    buttonHtml = `<button class="friend-action-btn friends" disabled>✓ Friends</button>`;
                } else if (user.friendStatus === 'pending') {
                    buttonHtml = `<button class="friend-action-btn pending" disabled>⏳ Pending</button>`;
                } else {
                    buttonHtml = `<button class="friend-action-btn add-friend" onclick="sendFriendRequest('${user.userId}', '${user.firstName} ${user.lastName}')">+ Add Friend</button>`;
                }

                const userNameDisplay = [64].map(c => String.fromCharCode(c))[0] + user.userName;
                resultsHtml += `
                    <div class="friend-result-card">
                        <div class="friend-result-avatar">
                            ${avatar}
                        </div>
                        <div class="friend-result-info">
                            <div class="friend-result-name">${user.firstName} ${user.lastName}</div>
                            <div class="friend-result-id">${userNameDisplay}</div>
                        </div>
                        <div class="friend-result-actions">
                            ${buttonHtml}
                        </div>
                    </div>
                `;
            });

            document.getElementById('searchResults').innerHTML = resultsHtml;
        })
        .catch(error => {
            console.error('Error:', error);
            document.getElementById('searchResults').innerHTML = `
                <div style="text-align: center; padding: 40px 20px; color: #ff6b6b;">
                    <i class="bi bi-exclamation-circle" style="font-size: 3rem; display: block; margin-bottom: 15px;"></i>
                    <p>Error searching for friends. Please try again.</p>
                </div>
            `;
        });
}

function sendFriendRequest(receiverId, userName) {
    // Get CSRF token - try to find it from any hidden input on the page
    let token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    
    // If not found, try to get it from meta tag (common pattern)
    if (!token) {
        token = document.querySelector('meta[name="csrf-token"]')?.content;
    }
    
    const formData = new FormData();
    formData.append('receiverId', receiverId);
    if (token) {
        formData.append('__RequestVerificationToken', token);
    }
    
    fetch(sendRequestUrl, {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: formData
    })
    .then(response => {
        if (!response.ok) {
            if (response.status === 400) {
                return response.text().then(msg => {
                    throw new Error(msg || 'Invalid request');
                });
            }
            throw new Error('Failed to send request');
        }
        return response.text();
    })
    .then(data => {
        showToast(`Friend request sent to ${userName}!`, 'success');
        // Refresh search results to update button state
        setTimeout(() => searchFriends(), 800);
    })
    .catch(error => {
        console.error('Error:', error);
        showToast(error.message || 'Error sending friend request. Please try again.', 'error');
    });
}


// Clear search and reset modal when it closes
document.addEventListener('DOMContentLoaded', function() {
    const makeFriendsModal = document.getElementById('makeFriendsModal');
    
    if (makeFriendsModal) {
        makeFriendsModal.addEventListener('hidden.bs.modal', function() {
            // Clear the search input
            document.getElementById('friendSearchInput').value = '';
            // Reset the results
            document.getElementById('searchResults').innerHTML = `
                <div style="text-align: center; padding: 40px 20px; color: var(--text-secondary);">
                    <i class="bi bi-search" style="font-size: 3rem; opacity: 0.5; display: block; margin-bottom: 15px;"></i>
                    <p>Start typing to search for friends</p>
                </div>
            `;
        });
    }
    
    // Allow Enter key to trigger search
    const searchInput = document.getElementById('friendSearchInput');
    if (searchInput) {
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                searchFriends();
            }
        });
    }
});
</script>




