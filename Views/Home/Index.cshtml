@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    /* Dashboard Specific Styles */
    .dashboard-container {
        animation: fadeInUp 0.8s ease;
    }

    .welcome-section {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(240, 147, 251, 0.15) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 15px;
        padding: 40px 30px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
        animation: slideInLeft 0.6s ease;
    }

    .welcome-section::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(240, 147, 251, 0.1) 0%, transparent 70%);
        border-radius: 50%;
    }

    .welcome-section h1 {
        font-size: 2.5rem;
        font-weight: 700;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        position: relative;
        z-index: 1;
    }

    .welcome-section p {
        color: var(--text-secondary);
        font-size: 1.1rem;
        position: relative;
        z-index: 1;
    }

    /* Feature Cards */
    .feature-card {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 20px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        position: relative;
        overflow: hidden;
        animation: fadeInUp 0.6s ease backwards;
    }

    .feature-card:nth-child(1) { animation-delay: 0.1s; }
    .feature-card:nth-child(2) { animation-delay: 0.2s; }
    .feature-card:nth-child(3) { animation-delay: 0.3s; }
    .feature-card:nth-child(4) { animation-delay: 0.4s; }
    .feature-card:nth-child(5) { animation-delay: 0.5s; }
    .feature-card:nth-child(6) { animation-delay: 0.6s; }

    .feature-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(240, 147, 251, 0.1) 0%, rgba(102, 126, 234, 0.1) 100%);
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .feature-card:hover {
        transform: translateY(-8px);
        border-color: rgba(102, 126, 234, 0.5);
        box-shadow: 0 20px 40px rgba(102, 126, 234, 0.2);
    }

    .feature-card:hover::before {
        opacity: 1;
    }

    .feature-icon {
        font-size: 3rem;
        margin-bottom: 15px;
        transition: all 0.4s ease;
    }

    .feature-card:hover .feature-icon {
        transform: scale(1.15) rotate(5deg);
    }

    .feature-card h5 {
        font-weight: 700;
        color: var(--text-primary);
        font-size: 1.3rem;
        margin-bottom: 10px;
        position: relative;
        z-index: 2;
    }

    .feature-card p {
        color: var(--text-secondary);
        margin-bottom: 15px;
        position: relative;
        z-index: 2;
    }

    .feature-card .btn {
        position: relative;
        z-index: 2;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 8px 20px;
        border-radius: 6px;
        font-weight: 600;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        width: 100%;
        text-align: center;
    }

    .feature-card .btn:hover {
        transform: translateX(5px);
        box-shadow: 0 10px 20px rgba(102, 126, 234, 0.4);
    }

    /* Section Headers */
    .section-header {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 2px solid rgba(102, 126, 234, 0.2);
    }

    .section-header h2 {
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .section-header i {
        font-size: 1.8rem;
        color: #667eea;
    }

    /* Stats Section */
    .stat-box {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        transition: all 0.3s ease;
        animation: fadeInUp 0.6s ease backwards;
    }

    .stat-box:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(102, 126, 234, 0.15);
    }

    .stat-box .number {
        font-size: 2.5rem;
        font-weight: 700;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .stat-box .label {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-top: 5px;
    }

    /* CTA Button */
    .cta-button {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .cta-button:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 35px rgba(102, 126, 234, 0.4);
        color: white;
        text-decoration: none;
    }

    /* Quick Actions */
    .quick-action {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 10px;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .quick-action:hover {
        transform: translateX(5px);
        border-color: rgba(102, 126, 234, 0.5);
    }

    .quick-action i {
        font-size: 1.5rem;
        color: #667eea;
    }

    .quick-action-text h6 {
        margin: 0;
        font-weight: 600;
        color: var(--text-primary);
    }

    .quick-action-text p {
        margin: 3px 0 0 0;
        font-size: 0.85rem;
        color: var(--text-secondary);
    }
</style>

@if (User?.Identity?.IsAuthenticated ?? false)
{
    <div class="dashboard-container">
        <!-- Welcome Section -->
        <div class="welcome-section">
            @{
                var currentUser = await UserManager.GetUserAsync(User);
                var displayName = currentUser?.FirstName ?? User.Identity.Name;
            }
            <h1>Welcome back, <span style="color: #667eea;">@displayName</span>! 👋</h1>
            <p>Share your thoughts, explore fascinating stories, and connect with writers around the world.</p>
        </div>

        @if (ViewData["IsFirstLogin"] != null && (bool)ViewData["IsFirstLogin"])
        {
            <!-- Getting Started Section - First Login Only -->
            <div class="section-header">
                <i class="bi bi-rocket"></i>
                <h2>Getting Started</h2>
            </div>

            <div class="row mb-5">
                <div class="col-lg-6 mb-4">
                    <div class="quick-action" onclick="location.href='@Url.Action("Index", "Profile")'" style="cursor: pointer;">
                        <i class="bi bi-1-circle"></i>
                        <div class="quick-action-text">
                            <h6>Complete Your Profile</h6>
                            <p>Add a profile picture, bio, and interests to help others find you.</p>
                        </div>
                    </div>

                    <div class="quick-action" onclick="location.href='@Url.Action("Create", "Journal")'" style="cursor: pointer;">
                        <i class="bi bi-2-circle"></i>
                        <div class="quick-action-text">
                            <h6>Create Your First Journal</h6>
                            <p>Start your journey by sharing your first thought or story.</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6 mb-4">
                    <div class="quick-action" onclick="location.href='@Url.Action("Index", "Explore")'" style="cursor: pointer;">
                        <i class="bi bi-3-circle"></i>
                        <div class="quick-action-text">
                            <h6>Explore Journals</h6>
                            <p>Browse writings, discover authors, and find interesting content.</p>
                        </div>
                    </div>

                    <div class="quick-action" onclick="location.href='@Url.Action("Index", "Friends")'" style="cursor: pointer;">
                        <i class="bi bi-4-circle"></i>
                        <div class="quick-action-text">
                            <h6>Add Friends</h6>
                            <p>Connect with writers and build your community network.</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Stats Section -->
        <div class="row mb-5">
            <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
                <div class="stat-box">
                    <div class="number">@ViewData["PublishedJournalsCount"]</div>
                    <div class="label">Journals Published</div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
                <div class="stat-box">
                    <div class="number">@ViewData["FriendsCount"]</div>
                    <div class="label">Friends</div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
                <div class="stat-box">
                    <div class="number">@ViewData["ReadersCount"]</div>
                    <div class="label">Readers</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
                <div class="stat-box">
                    <div class="number">@ViewData["LikesCount"]</div>
                    <div class="label">Likes Received</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
                <div class="stat-box">
                    <div class="number">@ViewData["CommentsCount"]</div>
                    <div class="label">Comments Received</div>
                </div>
            </div>
        </div>

        <!-- Main Features Section -->
        <div class="section-header">
            <i class="bi bi-star"></i>
            <h2>Quick Actions</h2>
        </div>

        <div class="row mb-5">
            <!-- Create Journal -->
            <div class="col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon">✍️</div>
                    <h5>Create Journal</h5>
                    <p>Write and share your thoughts with the world. Make it private for yourself or public for readers.</p>
                    <a href="@Url.Action("Create", "Journal")" class="btn btn-sm">
                        <i class="bi bi-plus-lg" style="font-size: 1.2rem; font-weight: bold;"></i> New Journal
                    </a>
                </div>
            </div>

            <!-- Explore Writings -->
            <div class="col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon">🔍</div>
                    <h5>Explore Writings</h5>
                    <p>Discover fascinating journals and stories by topic, author, or trending content.</p>
                    <a href="@Url.Action("Index", "Explore")" class="btn btn-sm">
                        <i class="bi bi-compass"></i> Browse
                    </a>
                </div>
            </div>

            <!-- Make Friends -->
            <div class="col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon">👥</div>
                    <h5>Make Friends</h5>
                    <p>Connect with other writers and readers. Build your community and network.</p>
                    <a href="@Url.Action("Index", "Friends")" class="btn btn-sm">
                        <i class="bi bi-people"></i> Connect
                    </a>
                </div>
            </div>

            <!-- Browse by Topic -->
            <div class="col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon">📚</div>
                    <h5>Browse by Topic</h5>
                    <p>Find journals organized by categories. From science to romance, philosophy to travel.</p>
                    <a href="@Url.Action("Index", "Topic")" class="btn btn-sm">
                        <i class="bi bi-tags"></i> Categories
                    </a>
                </div>
            </div>

            <!-- My Library -->
            <div class="col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon">📖</div>
                    <h5>My Library</h5>
                    <p>View and manage all your saved journals from other writers you've bookmarked.</p>
                    <a href="@Url.Action("Library", "Journal")" class="btn btn-sm">
                        <i class="bi bi-bookmark"></i> Saved Journals
                    </a>
                </div>
            </div>

            <!-- Friends Feed -->
            <div class="col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon">📬</div>
                    <h5>Friends Feed</h5>
                    <p>See the latest writings from your friends and stay updated with their stories.</p>
                    <a href="@Url.Action("Index", "Feed")" class="btn btn-sm">
                        <i class="bi bi-chat-dots"></i> View Feed
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Create Journal Modal -->
    <div class="modal fade" id="createJournalModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content" style="background: #1a1f2e; border: 1px solid rgba(102, 126, 234, 0.2);">
                <div class="modal-header border-bottom border-secondary">
                    <h5 class="modal-title">Create New Journal</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form>
                        <div class="mb-3">
                            <label class="form-label">Journal Title</label>
                            <input type="text" class="form-control" style="background: #0f1419; border: 1px solid rgba(102, 126, 234, 0.2); color: var(--text-primary);" placeholder="Enter title...">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Content</label>
                            <textarea class="form-control" rows="5" style="background: #0f1419; border: 1px solid rgba(102, 126, 234, 0.2); color: var(--text-primary);" placeholder="Write your thoughts..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Topic</label>
                            <select class="form-select" style="background: #0f1419; border: 1px solid rgba(102, 126, 234, 0.2); color: var(--text-primary);">
                                <option>Select topic...</option>
                                <option>Science</option>
                                <option>Technology</option>
                                <option>Travel</option>
                                <option>Philosophy</option>
                                <option>Romance</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Privacy</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="privacy" id="private" value="private" checked>
                                <label class="form-check-label" for="private">
                                    <i class="bi bi-lock"></i> Private (Only you can see)
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="privacy" id="public" value="public">
                                <label class="form-check-label" for="public">
                                    <i class="bi bi-unlock"></i> Public (Everyone can see)
                                </label>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-top border-secondary">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="cta-button">Publish Journal</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Topics Modal -->
    <div class="modal fade" id="topicsModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content" style="background: #1a1f2e; border: 1px solid rgba(102, 126, 234, 0.2);">
                <div class="modal-header border-bottom border-secondary">
                    <h5 class="modal-title">Browse by Topic</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        @foreach (var topic in new[] { "Science", "Technology", "Travel", "Philosophy", "Romance", "Food", "Health", "Education", "Business", "Art" })
                        {
                            <div class="col-md-6 mb-3">
                                <a href="#" class="text-decoration-none">
                                    <div class="feature-card">
                                        <h6>@topic</h6>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- Section 1: Hero Welcome Section -->
    <section class="snap-section hero-section">
        <div class="section-content">
            <div style="margin-bottom: 30px; animation: fadeInUp 0.8s ease;">
                <i class="bi bi-book" style="font-size: 5rem; color: #667eea;"></i>
            </div>
            <h1 style="font-size: 3rem; font-weight: 700; margin-bottom: 15px; animation: fadeInUp 0.8s ease 0.1s backwards;">
                Welcome to <span style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">InkVault</span>
            </h1>
            <p style="font-size: 1.2rem; color: var(--text-secondary); margin-bottom: 30px; animation: fadeInUp 0.8s ease 0.2s backwards;">
                Your personal journal platform to share thoughts, discover stories, and connect with writers worldwide.
            </p>
            <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; animation: fadeInUp 0.8s ease 0.3s backwards;">
                <a asp-controller="Account" asp-action="Welcome" class="cta-button" id="loginBtn">
                    <i class="bi bi-box-arrow-in-right"></i> Login Now
                </a>
                <a asp-controller="Account" asp-action="Register" class="cta-button" id="joinBtn" style="background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 75, 162, 0.2) 100%); border: 1px solid rgba(102, 126, 234, 0.4); color: #667eea;">
                    <i class="bi bi-person-plus"></i> Join Community
                </a>
            </div>

            <!-- Scroll Indicator - Clickable -->
            <a href="#features" class="scroll-indicator" style="text-decoration: none;">
                <i class="bi bi-chevron-down"></i>
                <p style="font-size: 0.9rem; color: var(--text-secondary); margin-top: 5px;">Scroll to explore features</p>
            </a>

                <style>
                    [data-theme="light"] #joinBtn {
                        background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%) !important;
                        border: 2px solid #667eea !important;
                        color: #667eea !important;
                    }

                    [data-theme="light"] #joinBtn:hover {
                        background: linear-gradient(135deg, rgba(102, 126, 234, 0.25) 0%, rgba(118, 75, 162, 0.25) 100%) !important;
                        color: #667eea !important;
                        text-decoration: none;
                    }

                    .scroll-indicator {
                        position: absolute;
                        bottom: 70px;
                        left: 50%;
                        transform: translateX(-50%);
                        text-align: center;
                        animation: bounceUpDown 2s ease-in-out infinite;
                        cursor: pointer;
                        transition: all 0.3s ease;
                    }

                    .scroll-indicator:hover {
                        transform: translateX(-50%) scale(1.1);
                    }

                    .scroll-indicator i {
                        font-size: 2rem;
                        color: #667eea;
                        display: block;
                        margin-bottom: 5px;
                    }

                    .scroll-indicator p {
                        margin: 0;
                        padding: 0;
                    }

                    @@keyframes bounceUpDown {
                        0%, 100% { transform: translate(-50%, 0); }
                        50% { transform: translate(-50%, 10px); }
                    }
                </style>
            </div>
        </section>

        <!-- Section 2: Platform Features Section -->
        <section id="features" class="snap-section features-section">
            <div class="section-content">
                <div style="text-align: center; margin-bottom: 50px; animation: fadeInUp 0.8s ease;">
                    <div style="display: inline-flex; align-items: center; gap: 12px; padding-bottom: 15px; border-bottom: 2px solid rgba(102, 126, 234, 0.25);">
                        <i class="bi bi-star-fill" style="font-size: 2rem; color: #667eea;"></i>
                        <h2 style="font-size: 2.2rem; margin: 0; font-weight: 700; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Platform Features</h2>
                    </div>
                    <p style="color: var(--text-secondary); margin-top: 15px; font-size: 1.05rem;">Discover what you can do on InkVault</p>
                </div>

                <div class="container">
                    <div class="row g-4">
                        <!-- Feature 1: Write & Publish Journals -->
                        <div class="col-lg-4 col-md-6">
                            <div class="info-feature-card">
                                <div class="feature-icon-circle">
                                    <i class="bi bi-journal-text"></i>
                                </div>
                                <h5>Write & Publish Journals</h5>
                                <p>Create personal journals and publish them publicly or privately with full control.</p>
                            </div>
                        </div>

                        <!-- Feature 2: Abstract & Full Content Control -->
                        <div class="col-lg-4 col-md-6">
                            <div class="info-feature-card">
                                <div class="feature-icon-circle">
                                    <i class="bi bi-file-earmark-lock2"></i>
                                </div>
                                <h5>Abstract & Full Content Control</h5>
                                <p>Share abstracts and allow readers to request full access when needed.</p>
                            </div>
                        </div>

                        <!-- Feature 3: Connect with Writers -->
                        <div class="col-lg-4 col-md-6">
                            <div class="info-feature-card">
                                <div class="feature-icon-circle">
                                    <i class="bi bi-people-fill"></i>
                                </div>
                                <h5>Connect with Writers</h5>
                                <p>Follow friends and explore journals from other users in the community.</p>
                            </div>
                        </div>

                        <!-- Feature 4: Save to Library -->
                        <div class="col-lg-4 col-md-6">
                            <div class="info-feature-card">
                                <div class="feature-icon-circle">
                                    <i class="bi bi-bookmark-heart"></i>
                                </div>
                                <h5>Save to Library</h5>
                                <p>Bookmark journals and access them anytime from your personal library.</p>
                            </div>
                        </div>

                        <!-- Feature 5: AI Writing Assistant -->
                        <div class="col-lg-4 col-md-6">
                            <div class="info-feature-card">
                                <div class="feature-icon-circle">
                                    <i class="bi bi-magic"></i>
                                </div>
                                <h5>AI Writing Assistant</h5>
                                <p>Enhance your writing with grammar and readability improvements.</p>
                            </div>
                        </div>

                        <!-- Feature 6: Secure & Private -->
                        <div class="col-lg-4 col-md-6">
                            <div class="info-feature-card">
                                <div class="feature-icon-circle">
                                    <i class="bi bi-shield-check"></i>
                                </div>
                                <h5>Secure & Private</h5>
                                <p>OTP verification and customizable notification settings for your security.</p>
                            </div>
                        </div>
                    </div>
                </div>
                </div>
            </section>

            <style>
                /* Smooth Scrolling */
                html {
                    scroll-behavior: smooth;
                }

                /* Each Full-Screen Section */
                .snap-section {
                    min-height: 100vh;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    position: relative;
                    padding: 20px;
                }

                .section-content {
                    width: 100%;
                    max-width: 1400px;
                    margin: 0 auto;
                    text-align: center;
                }

                /* Hero Section Specific - Perfectly Centered */
                .hero-section {
                    height: 100vh;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    padding-top: 0;
                    padding-bottom: 140px;
                }

                .hero-section .section-content {
                    padding: 0 20px;
                    margin-top: -80px;
                }

                /* Features Section Specific */
                .features-section {
                    padding-top: 60px;
                    padding-bottom: 60px;
                }

        /* Info Feature Cards - Non-clickable, purely informational */
        .info-feature-card {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.12) 0%, rgba(118, 75, 162, 0.12) 100%);
            border: 2px solid rgba(102, 126, 234, 0.25);
            border-radius: 15px;
            padding: 35px 25px;
            text-align: center;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            height: 100%;
            position: relative;
            overflow: hidden;
        }

        .info-feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(240, 147, 251, 0.08) 0%, rgba(102, 126, 234, 0.08) 100%);
            opacity: 0;
            transition: opacity 0.4s ease;
            z-index: 0;
        }

        .info-feature-card:hover {
            transform: translateY(-10px);
            border-color: rgba(102, 126, 234, 0.5);
            box-shadow: 0 25px 50px rgba(102, 126, 234, 0.25);
        }

        .info-feature-card:hover::before {
            opacity: 1;
        }

        .feature-icon-circle {
            width: 80px;
            height: 80px;
            margin: 0 auto 20px;
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 75, 162, 0.2) 100%);
            border: 2px solid rgba(102, 126, 234, 0.4);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.4s ease;
            position: relative;
            z-index: 1;
        }

        .info-feature-card:hover .feature-icon-circle {
            transform: scale(1.1) rotate(5deg);
            box-shadow: 0 0 30px rgba(102, 126, 234, 0.4);
        }

        .feature-icon-circle i {
            font-size: 2rem;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .info-feature-card h5 {
            font-weight: 700;
            color: var(--text-primary);
            font-size: 1.25rem;
            margin-bottom: 12px;
            position: relative;
            z-index: 1;
        }

        .info-feature-card p {
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.6;
            margin: 0;
            position: relative;
            z-index: 1;
        }

        /* Light theme support */
        [data-theme="light"] .info-feature-card {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
            border-color: rgba(102, 126, 234, 0.2);
        }

        [data-theme="light"] .feature-icon-circle {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
            border-color: rgba(102, 126, 234, 0.3);
        }

        /* Responsive adjustments */
        @@media (max-width: 768px) {
            .snap-section {
                padding: 15px;
                min-height: auto;
            }

            .hero-section {
                padding-top: 60px;
                padding-bottom: 60px;
            }

            .features-section {
                padding-top: 40px;
                padding-bottom: 40px;
            }

            .info-feature-card {
                padding: 25px 20px;
            }

            .feature-icon-circle {
                width: 70px;
                height: 70px;
            }

            .feature-icon-circle i {
                font-size: 1.75rem;
            }

            .info-feature-card h5 {
                font-size: 1.15rem;
            }

            .info-feature-card p {
                font-size: 0.9rem;
            }

            .scroll-indicator {
                bottom: 60px;
            }

            .scroll-indicator i {
                font-size: 1.5rem;
            }

            .scroll-indicator p {
                font-size: 0.75rem;
            }
        }

        @@media (max-width: 576px) {
            .snap-section h1 {
                font-size: 2rem !important;
            }

            .snap-section h2 {
                font-size: 1.5rem !important;
            }

            .scroll-indicator {
                bottom: 50px;
            }
        }
    </style>
}

<script>
    // Add scroll animation
    document.addEventListener('DOMContentLoaded', function() {
        const cards = document.querySelectorAll('.feature-card');
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                }
            });
        }, { threshold: 0.1 });

        cards.forEach(card => {
            observer.observe(card);
        });
    });
</script>

