@model List<InkVault.ViewModels.TopicCardViewModel>

@{
    ViewData["Title"] = "Browse by Topic";
}

<style>
    .topics-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
        animation: fadeInUp 0.8s ease;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 50px;
        padding-bottom: 20px;
        border-bottom: 2px solid rgba(102, 126, 234, 0.2);
    }

    .page-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .page-header p {
        color: var(--text-secondary);
        font-size: 1rem;
        margin: 0;
    }

    .topics-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 25px;
    }

    .topic-card {
        background: var(--card-bg);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 30px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 200px;
        position: relative;
        overflow: hidden;
    }

    .topic-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        transition: left 0.3s ease;
    }

    .topic-card:hover::before {
        left: 0;
    }

    .topic-card:hover {
        transform: translateY(-8px);
        border-color: #667eea;
        box-shadow: 0 20px 40px rgba(102, 126, 234, 0.2);
    }

    .topic-card-content {
        position: relative;
        z-index: 1;
        width: 100%;
    }

    .topic-icon {
        font-size: 3rem;
        margin-bottom: 15px;
        color: #667eea;
    }

    .topic-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 10px;
        text-transform: capitalize;
    }

    .topic-count {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        background: rgba(102, 126, 234, 0.15);
        color: #667eea;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 30px;
    }

    .empty-state i {
        font-size: 4rem;
        color: var(--text-secondary);
        opacity: 0.5;
        margin-bottom: 20px;
    }

    .empty-state h2 {
        font-size: 1.8rem;
        color: var(--text-primary);
        margin: 0 0 10px 0;
    }

    .empty-state p {
        color: var(--text-secondary);
        font-size: 1rem;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        margin-bottom: 30px;
    }

    .back-btn:hover {
        background: rgba(102, 126, 234, 0.3);
        color: #667eea;
        text-decoration: none;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    [data-theme="light"] .topic-card {
        background: #ffffff !important;
        border-color: rgba(102, 126, 234, 0.15) !important;
    }

    [data-theme="light"] .topic-name {
        color: var(--text-primary) !important;
    }

    @@media (max-width: 768px) {
        .topics-grid {
            grid-template-columns: 1fr;
        }

        .page-header h1 {
            font-size: 1.8rem;
        }
    }
</style>

<div class="topics-container">
    <a href="@Url.Action("Index", "Home")" class="back-btn">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>

    <div class="page-header">
        <i class="bi bi-bookmark-fill" style="font-size: 2.5rem; color: #667eea;"></i>
        <div>
            <h1>Browse by Topic</h1>
            <p>Discover journals organized by topics</p>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="topics-grid">
            @foreach (var topic in Model)
            {
                <a href="@Url.Action("ViewByTopic", "Topic", new { topicName = topic.TopicName })" 
                   class="topic-card" 
                   style="text-decoration: none; color: inherit;">
                    <div class="topic-card-content">
                        <div class="topic-icon">
                            <i class="bi bi-bookmark"></i>
                        </div>
                        <div class="topic-name">@topic.TopicName</div>
                        <div class="topic-count">
                            <i class="bi bi-journal-text"></i>
                            @topic.JournalCount @(topic.JournalCount == 1 ? "journal" : "journals")
                        </div>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="topics-grid">
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <h2>No Topics Available</h2>
                <p>There are no published journals with topics yet. Come back later to explore!</p>
            </div>
        </div>
    }
</div>
