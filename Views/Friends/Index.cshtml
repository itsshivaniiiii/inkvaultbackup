        console.error('User ID is missing');
        return;
    }
    window.location.href = `/Profile/ViewPublic?userId=${encodeURIComponent(userId)}`;
}

// Function to update counts
function updateCounts() {
    fetch('/Friends/GetCounts')
        .then(response => response.json())
        .then(data => {
            document.getElementById('receivedCount').textContent = data.receivedCount;
            document.getElementById('sentCount').textContent = data.sentCount;
        })
        .catch(error => console.error('Error updating counts:', error));
}

// Real-time search functionality
let searchTimeout;
const searchInput = document.getElementById('searchInput');
if (searchInput) {
    searchInput.addEventListener('input', function(e) {
        clearTimeout(searchTimeout);
        const searchQuery = this.value.trim();
        
        if (searchQuery.length === 0) {
            document.querySelector('.section:first-of-type')?.remove();
            return;
        }

        // Debounce search - wait 300ms after user stops typing
        searchTimeout = setTimeout(() => {
            performSearch(searchQuery);
        }, 300);
    });
}

// Perform the actual search
function performSearch(query) {
    fetch(`/Friends/Index?search=${encodeURIComponent(query)}`, {
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.text())
    .then(html => {
        // Extract just the search results section from the response
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        const searchSection = doc.querySelector('.section:first-of-type');
        
        // Remove old search results if they exist
        const oldSection = document.querySelector('.friends-container .section:first-of-type');
        if (oldSection) {
            oldSection.remove();
        }
        
        // Add new search results
        if (searchSection) {
            const yourFriendsSection = document.querySelector('[id*="Your Friends"]')?.closest('.section');
            if (yourFriendsSection) {
                yourFriendsSection.parentNode.insertBefore(searchSection, yourFriendsSection);
            } else {
                document.querySelector('.friends-container').appendChild(searchSection);
            }
        }
    })
    .catch(error => console.error('Search error:', error));
}

// Navigate to user profile with Friends context
function viewProfile(userId) {
    window.location.href = `/Profile/ViewPublic/${userId}?fromFriends=true`;
}
