        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'friendId=' + encodeURIComponent(friendId) + 
              (csrfToken ? '&__RequestVerificationToken=' + encodeURIComponent(csrfToken) : '')
    })
    .then(response => {
