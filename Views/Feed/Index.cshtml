@model InkVault.ViewModels.FriendsFeedViewModel

@{
    ViewData["Title"] = "Friends Feed";
}

<style>
    .feed-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 40px 20px;
        animation: fadeInUp 0.8s ease;
    }

    .feed-header {
        margin-bottom: 40px;
        text-align: center;
    }

    .feed-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 10px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .feed-header p {
        color: var(--text-secondary);
        font-size: 1.1rem;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        margin-bottom: 30px;
    }

    .back-btn:hover {
        background: rgba(102, 126, 234, 0.3);
        color: #667eea;
        text-decoration: none;
    }

    .tabs-container {
        display: flex;
        gap: 10px;
        margin-bottom: 30px;
        border-bottom: 2px solid rgba(102, 126, 234, 0.2);
    }

    .tab-btn {
        padding: 15px 25px;
        background: transparent;
        border: none;
        color: var(--text-secondary);
        cursor: pointer;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        border-bottom: 3px solid transparent;
        position: relative;
        bottom: -2px;
    }

    .tab-btn:hover {
        color: #667eea;
    }

    .tab-btn.active {
        color: #667eea;
        border-bottom-color: #667eea;
    }

    .tab-content {
        display: none;
    }

    .tab-content.active {
        display: block;
        animation: fadeIn 0.3s ease;
    }

    .journals-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .journal-card {
        background: var(--card-bg);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 25px;
        transition: all 0.3s ease;
    }

    .journal-card:hover {
        transform: translateY(-3px);
        border-color: #667eea;
        box-shadow: 0 15px 30px rgba(102, 126, 234, 0.15);
    }

    .journal-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 15px;
        margin-bottom: 15px;
    }

    .author-info {
        display: flex;
        align-items: center;
        gap: 12px;
        flex: 1;
    }

    .author-avatar {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        flex-shrink: 0;
    }

    .author-avatar img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
    }

    .author-details h3 {
        margin: 0;
        color: var(--text-primary);
        font-weight: 600;
    }

    .author-details p {
        margin: 2px 0 0 0;
        color: var(--text-secondary);
        font-size: 0.85rem;
    }

    .journal-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 12px 0;
    }

    .journal-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 12px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(102, 126, 234, 0.1);
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .topic-badge {
        display: inline-block;
        padding: 4px 12px;
        background: rgba(102, 126, 234, 0.15);
        color: #667eea;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .journal-content {
        color: var(--text-secondary);
        line-height: 1.6;
        margin-bottom: 15px;
    }

    .journal-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .view-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .view-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        color: white;
        text-decoration: none;
    }

    .empty-state {
        text-align: center;
        padding: 60px 30px;
        background: rgba(102, 126, 234, 0.05);
        border: 1px dashed rgba(102, 126, 234, 0.2);
        border-radius: 12px;
    }

    .empty-state i {
        font-size: 4rem;
        color: var(--text-secondary);
        opacity: 0.5;
        margin-bottom: 20px;
    }

    .empty-state h2 {
        font-size: 1.8rem;
        color: var(--text-primary);
        margin: 0 0 10px 0;
    }

    .empty-state p {
        color: var(--text-secondary);
        font-size: 1rem;
    }

    .no-friends-state {
        text-align: center;
        padding: 80px 30px;
    }

    .no-friends-state i {
        font-size: 5rem;
        color: var(--text-secondary);
        opacity: 0.5;
        margin-bottom: 20px;
    }

    .no-friends-state h2 {
        font-size: 2rem;
        color: var(--text-primary);
        margin: 0 0 15px 0;
    }

    .no-friends-state p {
        color: var(--text-secondary);
        font-size: 1.1rem;
        margin-bottom: 30px;
    }

    .no-friends-state a {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 25px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .no-friends-state a:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
        text-decoration: none;
        color: white;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    [data-theme="light"] .journal-card {
        background: #ffffff !important;
        border-color: rgba(102, 126, 234, 0.15) !important;
    }

    [data-theme="light"] .journal-title {
        color: var(--text-primary) !important;
    }

    @@media (max-width: 768px) {
        .feed-header h1 {
            font-size: 1.8rem;
        }

        .journal-header {
            flex-direction: column;
        }

        .journal-footer {
            flex-direction: column;
            align-items: flex-start;
            gap: 15px;
        }

        .tabs-container {
            gap: 5px;
        }

        .tab-btn {
            padding: 12px 15px;
            font-size: 0.9rem;
        }
    }
</style>

<div class="feed-container">
    <a href="@Url.Action("Index", "Home")" class="back-btn">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>

    <div class="feed-header">
        <h1><i class="bi bi-newspaper"></i> Friends Feed</h1>
        <p>Discover the latest journals from your friends</p>
    </div>

    @if (!Model.HasFriends)
    {
        <div class="no-friends-state">
            <i class="bi bi-people"></i>
            <h2>No Friends Yet</h2>
            <p>You haven't added any friends yet. Start connecting to see their journals here!</p>
            <a href="@Url.Action("Index", "Friends")">
                <i class="bi bi-people-plus"></i> Find Friends
            </a>
        </div>
    }
    else
    {
        <!-- Tabs -->
        <div class="tabs-container">
            <button class="tab-btn active" data-tab="public">
                <i class="bi bi-globe"></i> Public Journals
            </button>
            <button class="tab-btn" data-tab="friends-only">
                <i class="bi bi-people-fill"></i> Friends-Only Journals
            </button>
        </div>

        <!-- Public Journals Tab -->
        <div id="public" class="tab-content active">
            @if (Model.PublicJournals.Any())
            {
                <div class="journals-list">
                    @foreach (var journal in Model.PublicJournals)
                    {
                        <div class="journal-card">
                            <div class="journal-header">
                                <div class="author-info">
                                    <div class="author-avatar">
                                        @if (!string.IsNullOrEmpty(journal.AuthorProfilePicture))
                                        {
                                            <img src="@journal.AuthorProfilePicture" alt="@journal.AuthorName" />
                                        }
                                        else
                                        {
                                            @journal.AuthorName.First()
                                        }
                                    </div>
                                    <div class="author-details">
                                        <h3>@journal.AuthorName</h3>
                                        <p>@journal.CreatedAt.ToString("MMM dd, yyyy")</p>
                                    </div>
                                </div>
                            </div>

                            <h2 class="journal-title">@journal.Title</h2>

                            <div class="journal-meta">
                                <div class="meta-item">
                                    <i class="bi bi-eye"></i>
                                    <span>@journal.ViewCount @(journal.ViewCount == 1 ? "view" : "views")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(journal.Topic))
                                {
                                    <span class="topic-badge">#@journal.Topic</span>
                                }
                            </div>

                            <div class="journal-content">
                                @journal.Content
                            </div>

                            <div class="journal-footer">
                                <a href="@Url.Action("View", "Journal", new { id = journal.JournalId, fromFeed = true })" class="view-btn">
                                    <i class="bi bi-eye"></i> Read Full Journal
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <h2>No Public Journals</h2>
                    <p>Your friends haven't published any public journals yet.</p>
                </div>
            }
        </div>

        <!-- Friends-Only Journals Tab -->
        <div id="friends-only" class="tab-content">
            @if (Model.FriendsOnlyJournals.Any())
            {
                <div class="journals-list">
                    @foreach (var journal in Model.FriendsOnlyJournals)
                    {
                        <div class="journal-card">
                            <div class="journal-header">
                                <div class="author-info">
                                    <div class="author-avatar">
                                        @if (!string.IsNullOrEmpty(journal.AuthorProfilePicture))
                                        {
                                            <img src="@journal.AuthorProfilePicture" alt="@journal.AuthorName" />
                                        }
                                        else
                                        {
                                            @journal.AuthorName.First()
                                        }
                                    </div>
                                    <div class="author-details">
                                        <h3>@journal.AuthorName</h3>
                                        <p>@journal.CreatedAt.ToString("MMM dd, yyyy")</p>
                                    </div>
                                </div>
                            </div>

                            <h2 class="journal-title">@journal.Title</h2>

                            <div class="journal-meta">
                                <div class="meta-item">
                                    <i class="bi bi-eye"></i>
                                    <span>@journal.ViewCount @(journal.ViewCount == 1 ? "view" : "views")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(journal.Topic))
                                {
                                    <span class="topic-badge">#@journal.Topic</span>
                                }
                            </div>

                            <div class="journal-content">
                                @journal.Content
                            </div>

                            <div class="journal-footer">
                                <a href="@Url.Action("View", "Journal", new { id = journal.JournalId, fromFeed = true })" class="view-btn">
                                    <i class="bi bi-eye"></i> Read Full Journal
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <h2>No Friends-Only Journals</h2>
                    <p>Your friends haven't shared any friends-only journals yet.</p>
                </div>
            }
        </div>
    }
</div>

<script>
    // Tab functionality
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const tabName = this.getAttribute('data-tab');
            
            // Remove active class from all buttons and content
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            
            // Add active class to clicked button and corresponding content
            this.classList.add('active');
            document.getElementById(tabName).classList.add('active');
        });
    });
</script>
